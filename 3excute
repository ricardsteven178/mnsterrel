local function executeScripts(scripts)
    if not scripts or #scripts == 0 then return end
    
    local readyToRun = {} -- Tabel untuk menyimpan script yang sudah siap eksekusi
    
    -- TAHAP 1: Download dan pastikan SEMUA script aman
    for _, scriptUrl in ipairs(scripts) do
        -- Coba download isi text dari github
        local success, result = pcall(function()
            return game:HttpGet(scriptUrl)
        end)
        
        -- Cek apakah gagal download atau link mati (404)
        if not success or result == "" or string.find(result, "404: Not Found") then
            warn("🚨 [CRITICAL ERROR] Gagal mendownload script!")
            warn("Link bermasalah: " .. tostring(scriptUrl))
            warn("❌ PROSES DIBATALKAN! Tidak ada satupun script yang dijalankan.")
            return -- Ini akan menghentikan seluruh fungsi, tidak ada yang dijalankan
        end
        
        -- Cek apakah text dari github bisa dijadikan kode lua yang valid (compile)
        local scriptFunction, compileError = loadstring(result)
        if not scriptFunction then
            warn("🚨 [CRITICAL ERROR] Script rusak / gagal dicompile!")
            warn("Link bermasalah: " .. tostring(scriptUrl))
            warn("Error Code: " .. tostring(compileError))
            warn("❌ PROSES DIBATALKAN! Tidak ada satupun script yang dijalankan.")
            return -- Berhenti total
        end
        
        -- Jika aman, simpan dulu fungsinya, jangan dijalankan dulu
        table.insert(readyToRun, scriptFunction)
        
        -- Beri jeda sangat kecil agar tidak kena rate-limit GitHub saat download massal
        task.wait(0.1) 
    end
    
    -- TAHAP 2: Jika kode sampai di baris ini, artinya 100% SCRIPT AMAN. Waktunya eksekusi!
    print("✅ Semua script berhasil di-download. Memulai eksekusi paralel...")
    for _, func in ipairs(readyToRun) do
        local co = coroutine.create(func)
        coroutine.resume(co)
    end
end

