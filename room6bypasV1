-- ==========================================
-- BACKGROUND COLOR TRACKER (SMART SOLVER)
-- ==========================================
local sequenceInstances = {}
local lastFlashTime = tick()
local buttonTasks = {}

local function startColorTracker(minigame)
    local colors = minigame:FindFirstChild("Colors")
    local xrayMonitor = minigame:FindFirstChild("xrayMonitor")
    local monitorScreen = xrayMonitor and xrayMonitor:FindFirstChild("Screen")
    local actionUI = monitorScreen and monitorScreen:FindFirstChild("UI") and monitorScreen.UI:FindFirstChild("Action")
    local resultUI = monitorScreen and monitorScreen:FindFirstChild("UI") and monitorScreen.UI:FindFirstChild("Result")
    
    if not colors then return end

    -- [RE-INITIALIZE OTAK MINIGAME 100% CLEAN]
    sequenceInstances = {}
    local conns = {}
    stopColorTracker = false
    cancelClicking = false
    isAutoPlayingMinigame = false 
    lastFlashTime = tick()

    if resultUI then
        table.insert(conns, resultUI:GetPropertyChangedSignal("Visible"):Connect(function()
            if resultUI.Visible then
                setStatus("⚠️ Game Reset (Player lain salah)! Menghapus memori warna...")
                sequenceInstances = {}
                cancelClicking = true
            end
        end))
    end

    for _, button in ipairs(colors:GetDescendants()) do
        if button:IsA("BasePart") and button.Name == "Button" then
            local conn = button:GetPropertyChangedSignal("BrickColor"):Connect(function()
                if stopColorTracker or isAutoPlayingMinigame then return end
                
                local warnaSekarang = tostring(button.BrickColor)
                if buttonTasks[button] then 
                    task.cancel(buttonTasks[button]) 
                    buttonTasks[button] = nil 
                end
                
                if warnaSekarang == "Black" then return end
                
                buttonTasks[button] = task.delay(0.25, function()
                    table.insert(sequenceInstances, button)
                    lastFlashTime = tick()
                    setStatus("Merekam: " .. warnaSekarang .. " (" .. #sequenceInstances .. ")")
                end)
            end)
            table.insert(conns, conn)
        end
    end

    local turnStartTime = 0
    local wasTurnToClick = false

    task.spawn(function()
        while not stopColorTracker do
            task.wait(0.3)
            
            local actionHeader = actionUI and actionUI:FindFirstChild("header")
            local actionNotice = actionUI and actionUI:FindFirstChild("notice")

            if not actionHeader or not actionNotice then continue end

            local headerText = string.lower(tostring(actionHeader.Text) .. tostring(actionHeader.ContentText))
            if headerText:match("completed") then
                setStatus("✅ Minigame Completed! Tracker berhenti.")
                break 
            end

            local noticeText = string.lower(tostring(actionNotice.Text) .. tostring(actionNotice.ContentText))
            local isTurnToClick = noticeText:match("copy")

            if isTurnToClick and not wasTurnToClick then
                turnStartTime = tick()
            end
            wasTurnToClick = isTurnToClick

            if isTurnToClick and not isAutoPlayingMinigame then
                if #sequenceInstances > 0 and (tick() - lastFlashTime) > 1.8 then
                    isAutoPlayingMinigame = true
                    cancelClicking = false
                    setStatus("🤖 Eksekusi Auto-Click (" .. #sequenceInstances .. "x)...")
                    
                    local currentSeq = {}
                    for _, v in ipairs(sequenceInstances) do table.insert(currentSeq, v) end
                    sequenceInstances = {} 
                    
                    enforceRoom6Position() 
                    
                    for i, btn in ipairs(currentSeq) do
                        if stopColorTracker or cancelClicking then 
                            setStatus("⏹ Eksekusi batal karena interupsi.")
                            break 
                        end
                        setStatus("-> Mengklik (" .. i .. "/" .. #currentSeq .. ")")
                        local clickDet = btn:FindFirstChildWhichIsA("ClickDetector")
                        if clickDet and fireclickdetector then fireclickdetector(clickDet) end
                        task.wait(0.6)
                    end
                    
                    task.wait(1)
                    isAutoPlayingMinigame = false
                    
                elseif #sequenceInstances == 0 and (tick() - turnStartTime) > 3 then
                    setStatus("⚠️ Data warna kosong! Sengaja menyalahkan untuk reset...")
                    enforceRoom6Position()
                    forceFailMinigame()
                    turnStartTime = tick() 
                    task.wait(1.5)
                end
            end
        end
        for _, c in ipairs(conns) do c:Disconnect() end
    end)
end

