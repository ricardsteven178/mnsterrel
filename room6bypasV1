local function getPatientData()
    local npcsFolder = workspace:FindFirstChild("NPCs")
    if not npcsFolder then return nil, nil end

    for _, npc in ipairs(npcsFolder:GetChildren()) do
        local pt = npc.PrimaryPart or npc:FindFirstChildWhichIsA("BasePart")
        if pt and (pt.Position - Config.PatientStandCFrame.Position).Magnitude < Config.PatientRadius then
            
            -- [PENTING]: Hanya kembalikan pasien jika dia punya tombol (PP) aktif!
            -- Jika tubuhnya ada tapi tidak ada tombol, anggap dia cuma "Ghost" lewat.
            local activePP = nil
            for _, desc in ipairs(npc:GetDescendants()) do
                if desc:IsA("ProximityPrompt") and desc.Enabled then
                    local act = string.lower(desc.ActionText or "")
                    if act:match("dna") or act:match("treat") or act:match("burns") or act:match("inject") or desc.Name == "PP" or desc.Name == "FirePP" then
                        return npc, desc
                    end
                    activePP = desc
                end
            end
            
            if activePP then return npc, activePP end
            
            -- Coba cari fallback (PP utama) yang Enabled
            local fallbackPP = npc:FindFirstChild("PP") or npc:FindFirstChildWhichIsA("ProximityPrompt", true)
            if fallbackPP and fallbackPP.Enabled then
                return npc, fallbackPP
            end
        end
    end
    return nil, nil
end

