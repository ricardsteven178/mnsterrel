-- ==========================================
local function checkRoom6Active(path, minigame)
    if not minigame then return false end
    if isHealingDone(minigame) then return false end

    -- 1. Scan kebutuhan X-Ray, Monitor, atau Collect
    for _, pp in ipairs(minigame:GetDescendants()) do
        if pp:IsA("ProximityPrompt") and pp.Enabled then
            local txt = string.lower(pp.ActionText or "")
            if txt:match("x%-ray") or txt:match("process") or txt:match("collect") then
                return true
            end
        end
    end

    -- 2. Scan kebutuhan obat di TV
    local tvScreen = minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen", true)
    local invUI = tvScreen and tvScreen:FindFirstChild("inv", true)
    if invUI and #invUI:GetChildren() > 1 then
        for _, req in ipairs(invUI:GetChildren()) do
            if not req:IsA("UIListLayout") then
                local chk = req:FindFirstChild("check")
                if not chk or not chk.Visible then 
                    return true 
                end
            end
        end
    end

    -- 3. Scan pasien yang ada tombolnya (DNA/Treat)
    local patientNPC, patientPP = getPatientData()
    if patientNPC and patientPP then return true end

    -- 4. Scan Lampu Merah
    local signLight = path:FindFirstChild("MainSign") and path.MainSign:FindFirstChild("Light")
    if signLight and signLight:IsA("BasePart") and (signLight.BrickColor.Name == "Crimson" or signLight.Color == Color3.fromRGB(165, 0, 0)) then
        return true
    end

    return false
end

local function executeRoom6()
    local success, err = pcall(function()
        local path = workspace:FindFirstChild("Rooms") and workspace.Rooms:FindFirstChild("Emergency") and workspace.Rooms.Emergency:FindFirstChild("Room6")
        local minigame = path and path:FindFirstChild("Minigame")
        if not path or not minigame then return end

        local isRoomActive = checkRoom6Active(path, minigame)

        if not isRoomActive then 
            if not _G.Room6_IsIdle then
                unequipAll()
                teleportToIdle()
                _G.Room6_IsIdle = true
            end
            setStatus("Idle (Standby memantau R6)...")
            task.wait(Config.ScanDelay)
            return 
        end

        _G.Room6_IsIdle = false
        setStatus("Room 6 Aktif Terdeteksi! Menyiapkan R6...")
        enforceRoom6Position()
        
        -- [BYPASS AKTIF]: Fungsi tracker warna kita biarkan tidak dipanggil agar hemat memory
        -- startColorTracker(minigame)

        local isDone = false
        local lastProgressTime = tick() 
        local lastPendingCount = -1
        local emptyCounter = 0
        
        while not isDone and autoActive do
            task.wait(1)
            enforceRoom6Position()

            if isHealingDone(minigame) then
                setStatus("✅ Layar Healing TV menyala! Cabut ke Idle...")
                isDone = true
                break
            end

            -- Cek kalau beneran udah clear dan pasien ngilang
            if not checkRoom6Active(path, minigame) then
                emptyCounter = emptyCounter + 1
                if emptyCounter >= 3 then
                    setStatus("✅ Ruangan kosong melompong (Clear). Cabut ke Idle...")
                    isDone = true
                    break
                end
            else
                emptyCounter = 0
            end

            local patientNPC, patientPP = getPatientData()
            local tvScreen = minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen", true)

            -- 1. CEK SUNTIK OBAT
            local invUI = tvScreen and tvScreen:FindFirstChild("inv", true)
            if invUI and #invUI:GetChildren() > 1 then
                local pending = {}
                for _, req in ipairs(invUI:GetChildren()) do
                    if not req:IsA("UIListLayout") then
                        local chk = req:FindFirstChild("check")
                        if not chk or not chk.Visible then table.insert(pending, req.Name) end
                    end
                end
                
                if #pending ~= lastPendingCount then
                    lastPendingCount = #pending
                    lastProgressTime = tick()
                end

                if #pending == 0 then
                    setStatus("Obat selesai disuntik. Menunggu layar Healing...")
                    continue 
                else
                    if not patientPP then
                        setStatus("⚠️ Menunggu NPC Pasien muncul untuk disuntik...")
                        continue
                    end

                    if isAnomaly(patientNPC) then
                        setStatus("!! [ALGOJO] PASIEN INI ANOMALI/MONSTER !!")
                        local wrongMedicine = "Medicine"
                        for _, item in ipairs(ItemList) do
                            if not table.find(pending, item) then wrongMedicine = item break end
                        end
                        
                        local hasIt = LocalPlayer.Backpack:FindFirstChild(wrongMedicine) or LocalPlayer.Character:FindFirstChild(wrongMedicine)
                        if not hasIt then fetchItem(wrongMedicine, {wrongMedicine}) end
                        
                        enforceRoom6Position()
                        local tool = LocalPlayer.Backpack:FindFirstChild(wrongMedicine) or LocalPlayer.Character:FindFirstChild(wrongMedicine)
                        if tool then 
                            unequipAll()
                            task.wait(0.1)
                            LocalPlayer.Character.Humanoid:EquipTool(tool) 
                        end
                        task.wait(0.2)
                        
                        setStatus("MENYUNTIKKAN OBAT SALAH: " .. wrongMedicine)
                        interact(patientPP, 0.25)
                        setStatus("--- ANOMALI HANGUS! ---")
                        continue
                    end

                    for _, obat in ipairs(pending) do
                        local hasItem = LocalPlayer.Backpack:FindFirstChild(obat) or (LocalPlayer.Character and LocalPlayer.Character:FindFirstChild(obat))
                        if not hasItem then fetchItem(obat, pending) end
                        
                        enforceRoom6Position()
                        local tool = LocalPlayer.Backpack:FindFirstChild(obat)
                        local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
                        if tool and hum then 
                            unequipAll()
                            task.wait(0.1)
                            hum:EquipTool(tool) 
                        end
                        task.wait(0.2)
                        
                        setStatus("Menyuntikkan: " .. obat)
                        interact(patientPP, 0.25)
                    end
                    task.wait(1.5)
                    continue 
                end
            end

            -- 2. CEK COLLECT
            local collected = false
            for _, pp in ipairs(minigame:GetDescendants()) do
                if pp:IsA("ProximityPrompt") and pp.ActionText:match("Collect") and pp.Enabled then
                    setStatus("Mengambil Hasil (Collect)...")
                    enforceRoom6Position() 
                    interact(pp, 0.5)
                    lastProgressTime = tick()
                    collected = true
                    task.wait(1.5)
                    break
                end
            end
            if collected then continue end 

            -- 3. [BYPASS AKTIF] LANGSUNG PROCESS INSTAN (MENGGANTIKAN STEP X-RAY NORMAL)
            -- Kita buang pengecekan X-Ray sepenuhnya, abaikan mau X-Ray ada atau hilang. 
            -- Script langsung maksa menekan "Process" secara terus menerus!
            local bypassBerhasil = false
            local monitor = minigame:FindFirstChild("Monitor")
            if monitor then
                for _, pp in ipairs(monitor:GetDescendants()) do
                    if pp:IsA("ProximityPrompt") and string.lower(pp.ActionText or ""):match("process") then
                        setStatus("BYPASS AKTIF: Men-trigger Process Instan...")
                        enforceRoom6Position()
                        interact(pp, 0.25)
                        lastProgressTime = tick()
                        task.wait(1.5)
                        bypassBerhasil = true
                        break
                    end
                end
            end
            if bypassBerhasil then continue end

            -- 4. ANTI-STUCK WATCHDOG (HARD RESET)
            if tick() - lastProgressTime >= Config.StuckTimeout then
                setStatus("⚠️ Timeout! Membatalkan sesi & mereset dari nol...")
                enforceRoom6Position()
                forceFailMinigame()
                isDone = true 
                break
            else
                setStatus("Menunggu Collect / Proses Bypass... (Auto-reset jika stuck)")
            end
        end

        stopColorTracker = true 
        if not _G.Room6_IsIdle then
            unequipAll()
            teleportToIdle()
            _G.Room6_IsIdle = true
        end
    end)

    if not success then
        setStatus("❌ ERROR: " .. tostring(err))
        warn("[Auto Room 6 Error] ", err)
        task.wait(3) 
    end
end

