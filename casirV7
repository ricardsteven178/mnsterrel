						else
							-- [FIX V31]: AUTO-RECOVERY PROTOCOL
							-- Jika ada pasien tapi tidak ada tombol yang bisa dipencet (ter-disable karena kita terlalu jauh),
							-- Script akan otomatis menarik kita kembali ke meja kasir agar tombolnya muncul (ter-load) lagi!
							local char = LocalPlayer.Character
							local root = char and char:FindFirstChild("HumanoidRootPart")
							if root and (root.Position - Config.CashierCFrame.Position).Magnitude > 8 then
								logInfo("-> Posisi jauh dari kasir, mengkalibrasi ulang posisi...")
								teleportTo(Config.CashierCFrame, "Meja Kasir (Recovery)")
							end
						end
					end
					return 
				end
				
				if #anomalyNPCs > 0 then
					if shutterPP and shutterPP.ActionText == "Close" then
						logInfo("-> ANOMALI TERDETEKSI! Menutup Pintu...")
						teleportTo(Config.ShutterCFrame, "Tombol Shutter")
						firePrompt(shutterPP)
						teleportTo(Config.CashierCFrame, "Meja Kasir (Aman)")
					else
						-- Sama, kalibrasi jika jauh tapi butuh tutup pintu
						local char = LocalPlayer.Character
						local root = char and char:FindFirstChild("HumanoidRootPart")
						if root and (root.Position - Config.CashierCFrame.Position).Magnitude > 8 then
							teleportTo(Config.CashierCFrame, "Meja Kasir (Recovery)")
						end
					end
					return 
				end
				
				local checkIn1 = workspace:FindFirstChild("Misc") and workspace.Misc:FindFirstChild("CheckIn")
				local checkIn2 = workspace:FindFirstChild("Misc") and workspace.Misc:FindFirstChild("CheckIn2")
				
				local form1 = checkIn1 and checkIn1:FindFirstChild("Form")
				local form2 = checkIn2 and checkIn2:FindFirstChild("Form")
				
				if not form1 and not form2 and #normalNPCs == 0 and #anomalyNPCs == 0 then
					if shutterPP and shutterPP.ActionText == "Open" then
						logInfo("-> Meja bersih & kosong. Membuka gerbang...")
						teleportTo(Config.ShutterCFrame, "Tombol Shutter")
						firePrompt(shutterPP)
						teleportTo(Config.CashierCFrame, "Meja Kasir")
					end
				end
				
			end)
			
			if not success then
				logInfo("⚠️ SYSTEM ERROR: " .. tostring(err))
			end
		end
	end
end)

