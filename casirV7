local function updateVisualRadar(id, pos, radius, color, isVisible)
	if not isVisible then
		if _G.SmartCashier_Radars[id] then
			_G.SmartCashier_Radars[id]:Destroy()
			_G.SmartCashier_Radars[id] = nil
		end
		return
	end
	
	local radar = _G.SmartCashier_Radars[id]
	if not radar or not radar.Parent then
		radar = Instance.new("Part")
		radar.Name = "Radar_" .. id
		radar.Shape = Enum.PartType.Cylinder
		radar.Anchored = true
		radar.CanCollide = false
		radar.CanQuery = false
		radar.CastShadow = false
		radar.Material = Enum.Material.Neon
		radar.Transparency = 0.85
		radar.Color = color
		radar.Parent = workspace
		_G.SmartCashier_Radars[id] = radar
	end
	
	radar.Size = Vector3.new(0.1, radius * 2, radius * 2)
	radar.CFrame = CFrame.new(pos.X, pos.Y - 1.45, pos.Z) * CFrame.Angles(0, 0, math.rad(90))
end

local function getPromptPosition(prompt)
	local currentParent = prompt.Parent
	while currentParent do
		if currentParent:IsA("BasePart") or currentParent:IsA("Model") or currentParent:IsA("Tool") then
			local success, pos = pcall(function() return currentParent:GetPivot().Position end)
			if success then return pos end
		end
		currentParent = currentParent.Parent
	end
	return nil
end

local function teleportToPrompt(prompt)
	if not Config.TeleportSebelumMelayani then return end
	local pos = getPromptPosition(prompt)
	if pos then
		local char = LocalPlayer.Character
		local root = char and char:FindFirstChild("HumanoidRootPart")
		if root then
			root.CFrame = CFrame.new(pos + Vector3.new(0, 3.5, 0))
			root.Velocity = Vector3.new(0,0,0)
			task.wait(0.25) 
		end
	end
end

local function teleportTo(targetCFrame, namaLokasi)
	if not Config.TeleportSebelumMelayani then return end
	local char = LocalPlayer.Character
	local root = char and char:FindFirstChild("HumanoidRootPart")
	if root then
		local distance = (root.Position - targetCFrame.Position).Magnitude
		if distance > 3 then
			logInfo("Teleport -> " .. namaLokasi)
			root.CFrame = targetCFrame
			root.Velocity = Vector3.new(0,0,0)
			task.wait(0.2) 
		end
	end
end

-- Eksekusi Instan
local function firePrompt(prompt)
	if prompt and prompt:IsA("ProximityPrompt") then
		local oldReq = prompt.RequiresLineOfSight
		local oldDist = prompt.MaxActivationDistance
		local oldHold = prompt.HoldDuration
		
		prompt.RequiresLineOfSight = false
		prompt.MaxActivationDistance = math.huge
		prompt.HoldDuration = 0 
		
		if type(fireproximityprompt) == "function" then
			fireproximityprompt(prompt, 1, true)
		else
			prompt:InputHoldBegan() 
			task.wait(0.05) 
			prompt:InputHoldEnded()
		end
		
		prompt.RequiresLineOfSight = oldReq
		prompt.MaxActivationDistance = oldDist
		prompt.HoldDuration = oldHold
		
		return true
	end
	return false
end

local function isReady(prompt)
	if not prompt or not prompt.Enabled then return false end
	if actionCooldowns[prompt] and tick() < actionCooldowns[prompt] then return false end
	return true
end

