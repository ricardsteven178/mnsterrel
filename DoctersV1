end

local function getShiftText()
    local pGui = LocalPlayer:FindFirstChild("PlayerGui")
    if pGui then
        local shiftUI = pGui:FindFirstChild("Shift")
        if shiftUI then
            local frame  = shiftUI:FindFirstChild("Frame")
            local header = frame and frame:FindFirstChild("header")
            if header then
                local textChild = header:FindFirstChild("text")
                if textChild and textChild:IsA("TextLabel") then
                    local txt = textChild.Text:gsub("^%s*(.-)%s*$", "%1")
                    if txt ~= "" then return txt end
                end
                if header:IsA("TextLabel") then
                    local txt = header.Text:gsub("^%s*(.-)%s*$", "%1")
                    if txt ~= "" then return txt end
                end
            end
        end
    end
    return nil
end

local function getShiftNumber()
    local txt = getShiftText()
    if not txt then return nil end
    local num = txt:match("(%d+)")
    return num and tonumber(num) or nil
end

local function processNotifText(text)
    text = string.lower(text or "")
    if text:match("can't carry any more") or text:match("cannot carry") then
        local current, maxCap = text:match("%((%d+)/(%d+)%)")
        if maxCap then
            local limitServer = tonumber(maxCap)
            if limitServer and limitServer > 0 and Config.MaxInventory ~= limitServer then
                Config.MaxInventory = limitServer
                setStatus("✅ KALIBRASI TAS: Kapasitas shift ini = " .. limitServer)
            end
        end
    end

    if text:match("has died") or text:match("someone died") or text:match("died in room") then
        local roomNum = text:match("room (%d+)")
        if roomNum then
            roomNum = tonumber(roomNum)
            local isAnomaly = text:match("anomaly") ~= nil
            if isAnomaly then
                setStatus("✅ Anomali Room " .. roomNum .. " berhasil dibunuh!")
            else
                setStatus("⚠️ Pasien Room " .. roomNum .. " meninggal! Clear memory...")
            end
            if roomNum >= 1 and roomNum <= Config.MaxRooms then
                -- FIXED: Clear langsung saat NPC mati via notif — jangan pakai "JobDone" string
                -- karena string tidak bisa dibedakan dari NPC baru yang masuk ke room yang sama
                _G.AutoDoctor_RoomMemory[roomNum] = nil
                BuggedRoomBlacklist[roomNum] = nil
            elseif roomNum == 6 then
                _G.ER_Memory[6] = nil
            elseif roomNum == 7 then
                _G.ER_Memory[7] = nil
            elseif roomNum == 8 then
                _G.ER_Memory[8] = nil
            end
        end
    end
end

local function clearAllMedItems()
    local char     = LocalPlayer.Character
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    local hum      = char and char:FindFirstChild("Humanoid")
    local root     = char and char:FindFirstChild("HumanoidRootPart")
    if not char or not backpack or not hum or not root then return end

    hum:UnequipTools()
    task.wait(0.1)

    local function collectMedItems()
        local items = {}
        for _, item in ipairs(backpack:GetChildren()) do
            if item:IsA("Tool") and table.find(ItemList, item.Name) then
                table.insert(items, item)
            end
        end
        for _, item in ipairs(char:GetChildren()) do
            if item:IsA("Tool") and table.find(ItemList, item.Name) then
                table.insert(items, item)
            end
        end
        return items
    end

    local toTrash = collectMedItems()
    if #toTrash == 0 then return end

    setStatus("Membuang " .. #toTrash .. " sisa obat dari inventory...")

    local trashPrompt = _G.AutoDoctor_TrashCache
    if not trashPrompt or not trashPrompt.Parent then
        trashPrompt = nil
        for _, desc in ipairs(workspace:GetDescendants()) do
            if desc:IsA("ProximityPrompt") then
                local actText = string.lower(desc.ActionText or "")
                local objName = string.lower(desc.Parent and desc.Parent.Name or "")
                if actText:match("trash") or actText:match("throw") or actText:match("dispose") or objName:match("trash") then
                    _G.AutoDoctor_TrashCache = desc
                    trashPrompt = desc
                    break
                end
            end
        end
    end

    if not trashPrompt then
        setStatus("⚠️ Trash prompt tidak ditemukan, sisa obat tidak dibuang.")
        return
    end

    local trashPart = trashPrompt.Parent
    if trashPart then
        local pos = nil
        if trashPart:IsA("BasePart") then pos = trashPart.Position
        elseif trashPart:IsA("Model") then
            local bp = trashPart.PrimaryPart or trashPart:FindFirstChildWhichIsA("BasePart")
            if bp then pos = bp.Position end
        elseif trashPart:IsA("Attachment") then pos = trashPart.WorldPosition end
        if pos then
            root.CFrame = CFrame.new(pos + Vector3.new(0, 3, 0))
            root.Velocity = Vector3.zero
            root.AssemblyLinearVelocity = Vector3.zero
            task.wait(0.2)
        end
    end

    local oldReq  = trashPrompt.RequiresLineOfSight
    local oldDist = trashPrompt.MaxActivationDistance
    trashPrompt.RequiresLineOfSight   = false
    trashPrompt.MaxActivationDistance = math.huge
    trashPrompt.HoldDuration          = 0

    toTrash = collectMedItems()
    for _, item in ipairs(toTrash) do
        if item and item.Parent then
            hum:UnequipTools()
            task.wait(0.05)
            hum:EquipTool(item)
            task.wait(0.1)
            if type(fireproximityprompt) == "function" then
                fireproximityprompt(trashPrompt)
            else
                trashPrompt:InputHoldBegan()
                task.wait(0.05)
                trashPrompt:InputHoldEnded()
            end
            task.wait(0.15)
        end
    end

    trashPrompt.RequiresLineOfSight   = oldReq
    trashPrompt.MaxActivationDistance = oldDist

    hum:UnequipTools()
    task.wait(0.1)

    local remaining = collectMedItems()
    if #remaining > 0 then
        setStatus("⚠️ Masih ada " .. #remaining .. " obat tersisa (server lag). Coba ulang...")
        for _, item in ipairs(remaining) do
            if item and item.Parent then
                hum:UnequipTools(); task.wait(0.05)
                hum:EquipTool(item); task.wait(0.1)
                trashPrompt.RequiresLineOfSight   = false
                trashPrompt.MaxActivationDistance = math.huge
                if type(fireproximityprompt) == "function" then fireproximityprompt(trashPrompt)
                else trashPrompt:InputHoldBegan() task.wait(0.05) trashPrompt:InputHoldEnded() end
                trashPrompt.RequiresLineOfSight   = oldReq
                trashPrompt.MaxActivationDistance = oldDist
                task.wait(0.15)
            end
        end
        hum:UnequipTools()
    else
        setStatus("✅ Inventory bersih dari sisa obat.")
    end
end

