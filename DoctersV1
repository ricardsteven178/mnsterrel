-- ANOMALY KILLER HELPER — FIXED
-- Prioritas: cek inventory dulu, lalu scan workspace
-- Sort kandidat berdasarkan yang paling mudah didapat
-- Guard: tidak loop ulang setelah berhasil inject
-- ==========================================
local function findAndFetchWrongMedicine(prescribedMeds, fetchFn, roomTag)
    local bp   = LocalPlayer:FindFirstChild("Backpack")
    local char = LocalPlayer.Character

    -- Kumpulkan semua kandidat: item yang BUKAN bagian dari resep pasien
    local candidates = {}
    for _, item in ipairs(ItemList) do
        if not table.find(prescribedMeds, item) then
            table.insert(candidates, item)
        end
    end
    -- Pastikan "Medicine" selalu ada sebagai fallback terakhir
    if not table.find(candidates, "Medicine") then
        table.insert(candidates, "Medicine")
    end

    -- STEP 1: Cek yang sudah ada di inventory — paling cepat, zero fetch
    for _, item in ipairs(candidates) do
        bp   = LocalPlayer:FindFirstChild("Backpack")
        char = LocalPlayer.Character
        if (bp and bp:FindFirstChild(item)) or (char and char:FindFirstChild(item)) then
            if Config.ShowConsoleLogs then
                print("[AnomalyKiller] Racun di inventory: " .. item)
            end
            return item
        end
    end

    -- STEP 2: Scan workspace untuk semua kandidat yang promptnya ada
    -- Urutkan berdasarkan jarak dari player (ambil yang terdekat dulu)
    local root = char and char:FindFirstChild("HumanoidRootPart")
    local playerPos = root and root.Position or Vector3.zero

    local available = {}  -- { item=string, prompt=Instance, dist=number }
    for _, item in ipairs(candidates) do
        local tLower = string.lower(item)
        for _, desc in ipairs(workspace:GetDescendants()) do
            if desc:IsA("ProximityPrompt") and desc.Enabled then
                local pName = string.lower(desc.Parent and desc.Parent.Name or "")
                local oText = string.lower(desc.ObjectText or "")
                local aText = string.lower(desc.ActionText or "")
                if pName:match(tLower) or oText:match(tLower) or aText:match(tLower) then
                    local part = desc.Parent
                    local partPos = nil
                    if part:IsA("BasePart") then partPos = part.Position
                    elseif part:IsA("Attachment") then partPos = part.WorldPosition end
                    local dist = partPos and (partPos - playerPos).Magnitude or math.huge
                    table.insert(available, { item = item, prompt = desc, dist = dist })
                    break  -- satu prompt per item cukup
                end
            end
        end
    end

    -- Sort terdekat dulu
    table.sort(available, function(a, b) return a.dist < b.dist end)

    if Config.ShowConsoleLogs then
        print("[AnomalyKiller] Kandidat racun tersedia: " .. #available)
        for i, v in ipairs(available) do
            print("  [" .. i .. "] " .. v.item .. " (dist: " .. string.format("%.1f", v.dist) .. ")")
        end
    end

    -- STEP 3: Coba fetch satu per satu, terdekat dulu
    for _, entry in ipairs(available) do
        local item = entry.item
        if Config.ShowConsoleLogs then
            print("[AnomalyKiller] Coba ambil racun: " .. item)
        end
        local ok = fetchFn(item, {item})
        if ok then
            bp   = LocalPlayer:FindFirstChild("Backpack")
            char = LocalPlayer.Character
            if (bp and bp:FindFirstChild(item)) or (char and char:FindFirstChild(item)) then
                if Config.ShowConsoleLogs then
                    print("[AnomalyKiller] Racun berhasil diambil: " .. item)
                end
                return item
            end
        end
        -- Item tidak bisa diambil (stok kosong/server lag), coba berikutnya
    end

    -- STEP 4: Fallback paksa — coba "Medicine" walau tidak ada di available list
    if Config.ShowConsoleLogs then
        print("[AnomalyKiller] Semua kandidat gagal, fallback ke Medicine")
    end
    local okFallback = fetchFn("Medicine", {"Medicine"})
    if okFallback then
        bp   = LocalPlayer:FindFirstChild("Backpack")
        char = LocalPlayer.Character
        if (bp and bp:FindFirstChild("Medicine")) or (char and char:FindFirstChild("Medicine")) then
            return "Medicine"
        end
    end

    return nil
end

