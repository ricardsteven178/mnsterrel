-- Cari inBedPP lebih broad — nama InBed, atau action inject/apply/treat/use
local function findInBedPP_R7(minigame, currentPatient)
    if not minigame then return nil end
    local bed = minigame:FindFirstChild("Bed")
    if bed then
        local inBed = bed:FindFirstChild("InBed")
        if inBed then
            for _, pp in ipairs(inBed:GetDescendants()) do
                if pp:IsA("ProximityPrompt") then return pp end
            end
            local pp = inBed:FindFirstChildWhichIsA("ProximityPrompt")
            if pp then return pp end
        end
        for _, pp in ipairs(bed:GetDescendants()) do
            if pp:IsA("ProximityPrompt") and pp.Enabled then return pp end
        end
    end
    for _, pp in ipairs(minigame:GetDescendants()) do
        if pp:IsA("ProximityPrompt") then
            local name = string.lower(pp.Name or "")
            local act  = string.lower(pp.ActionText or "")
            if name == "pp" or name == "inbedpp" or name:match("bed")
            or act:match("inject") or act:match("apply") or act:match("treat") or act:match("use") then
                return pp
            end
        end
    end
    if currentPatient then
        for _, pp in ipairs(currentPatient:GetDescendants()) do
            if pp:IsA("ProximityPrompt") and pp.Enabled then
                local act = string.lower(pp.ActionText or "")
                if act:match("inject") or act:match("apply") or act:match("treat") then
                    return pp
                end
            end
        end
    end
    return nil
end

local function checkRoom7Status()
    local room7 = getEmergencyRoom(7)
    if not room7 then return nil, false end

    if _G.AutoRoom7_BlacklistTime > 0 and (tick() - _G.AutoRoom7_BlacklistTime < Config.BlacklistDuration) then
        if Config.ShowConsoleLogs then
            print("[R7] checkRoom7Status: SKIP — blacklist aktif")
        end
        return nil, false
    end

    local minigame = room7:FindFirstChild("Minigame")
    local currentPatient, _ = getPatientInEmergency(7, EmergencyCFrames[7].Step2, EmergencyCFrames[7].Radius)

    -- Track patient change — reset LegitHealing saat NPC berganti
    if currentPatient ~= _G.AutoRoom7_LastPatient then
        if Config.ShowConsoleLogs then
            local oldName = _G.AutoRoom7_LastPatient and _G.AutoRoom7_LastPatient.Name or "nil"
            local newName = currentPatient and currentPatient.Name or "nil"
            print("[R7] NPC berganti: " .. oldName .. " -> " .. newName .. " — reset LegitHealing & memory")
        end
        _G.AutoRoom7_LastPatient  = currentPatient
        _G.AutoRoom7_LegitHealing = false
        -- FIXED: Clear memory saat NPC berganti supaya NPC baru tidak ke-block
        _G.ER_Memory[7] = nil
    end

    -- Tidak ada pasien — clear memory
    if not currentPatient then
        _G.ER_Memory[7] = nil
        return nil, false
    end

    -- Cek memory — skip kalau NPC ini sudah selesai
    if erMemoryCheck(7, currentPatient) then
        if Config.ShowConsoleLogs then
            print("[R7] checkRoom7Status: SKIP — erMemory block NPC " .. currentPatient.Name)
        end
        return nil, false
    end

    -- Healing done check — set memory hanya kalau LegitHealing sudah true
    if isR7HealingDone(minigame) and _G.AutoRoom7_LegitHealing then
        if Config.ShowConsoleLogs then
            print("[R7] Healing selesai & legit — set memory, skip NPC ini")
        end
        erMemorySet(7, currentPatient)
        return nil, true
    end

    -- Ada pasien, belum memory blocked — return room7 untuk diproses
    if Config.ShowConsoleLogs then
        print("[R7] checkRoom7Status: AKTIF — NPC=" .. currentPatient.Name
            .. " | healing=" .. tostring(isR7HealingDone(minigame))
            .. " | legit=" .. tostring(_G.AutoRoom7_LegitHealing))
    end
    return room7, false
end

local function FireButton_R7(button)
    local wasActive = button.Active
    pcall(function() button.Active = true end)
    if typeof(getconnections) == "function" then
        pcall(function()
            for _, c in ipairs(getconnections(button.MouseButton1Down)) do task.spawn(function() pcall(function() c:Fire() end) end) end
            task.wait(0.05)
            for _, c in ipairs(getconnections(button.Activated)) do task.spawn(function() pcall(function() c:Fire() end) end) end
        end)
    elseif typeof(firesignal) == "function" then
        pcall(function() firesignal(button.MouseButton1Down) task.wait(0.05) firesignal(button.Activated) end)
    else
        local pos   = button.AbsolutePosition
        local size  = button.AbsoluteSize
        local inset = GuiService:GetGuiInset()
        local x = pos.X + size.X / 2
        local y = pos.Y + size.Y / 2 + inset.Y
        pcall(function()
            VirtualInputManager:SendMouseButtonEvent(x, y, 0, true, game, 0)
            task.wait(0.05)
            VirtualInputManager:SendMouseButtonEvent(x, y, 0, false, game, 0)
        end)
    end
    pcall(function() button.Active = wasActive end)
end

