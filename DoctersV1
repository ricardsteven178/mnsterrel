local function executeRoom7(room7, activeShift)
    -- Minigame UI check
    if isMinigameUIOpen_R7() then
        setStatus("Minigame Berjalan / Memproses Hasil...", "R7")
        _G.AutoRoom7_LastActionTick = tick()
        task.wait(1)
        return
    end

    local minigame = room7:FindFirstChild("Minigame")
    if not minigame then return end

    local currentPatient, _ = getPatientInEmergency(7, EmergencyCFrames[7].Step2, EmergencyCFrames[7].Radius)
    if not currentPatient then
        setStatus("Pasien pergi. Kembali Idle...", "R7")
        task.wait(1); return
    end

    -- Healing selesai dan kita yang inject — clear
    if isR7HealingDone(minigame) and _G.AutoRoom7_LegitHealing then
        setStatus("Pasien Sembuh! Kembali Idle...", "R7")
        erMemorySet(7, currentPatient)
        clearAllMedItems()
        task.wait(1); return
    end

    -- Pastikan ada di dalam ruangan
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if root and (root.Position - EmergencyCFrames[7].Step2.Position).Magnitude > 20 then
        setStatus("Memasuki Ruangan 7...", "R7")
        unequipAll()
        teleportToTarget(EmergencyCFrames[7].Step2)
        task.wait(0.5)
    end

    local tv = minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen")

    -- ==========================================
    -- STEP 1: Burns check di NPC
    -- ==========================================
    for _, desc in ipairs(currentPatient:GetDescendants()) do
        if desc:IsA("ProximityPrompt") and desc.Enabled then
            local actText = string.lower(desc.ActionText or "")
            local name    = string.lower(desc.Name or "")
            if name == "firepp" or actText:match("burns") then
                local hasOintment = LocalPlayer.Backpack:FindFirstChild("Ointment") or LocalPlayer.Character:FindFirstChild("Ointment")
                if not hasOintment then fetchItem_R7("Ointment", {"Ointment"}) end
                teleportToTarget(desc.Parent)
                if safeEquip_R7("Ointment") then
                    setStatus("Mengoleskan Ointment (Burns)...", "R7")
                    simpleInteract_R7(desc, 3, false)
                    _G.AutoRoom7_LastActionTick = tick()
                    task.wait(1.5); return
                end
            end
        end
    end

    -- ==========================================
    -- STEP 2: DNA check di NPC
    -- ==========================================
    for _, desc in ipairs(currentPatient:GetDescendants()) do
        if desc:IsA("ProximityPrompt") and desc.Enabled then
            local actText = string.lower(desc.ActionText or "")
            local name    = string.lower(desc.Name or "")
            if actText:match("dna") or name:match("dna") then
                unequipAll()
                setStatus("Mengambil DNA Sample...", "R7")
                simpleInteract_R7(desc, 0.5, true)
                _G.AutoRoom7_LastActionTick = tick()
                task.wait(1.5); return
            end
        end
    end

    -- ==========================================
    -- STEP 3: TV Report — inject obat
    -- FIXED: Pakai findInBedPP_R7 yang lebih broad
    -- ==========================================
    local reportUI  = tv and tv:FindFirstChild("UI") and tv.UI:FindFirstChild("Report")
    local invFolder = reportUI and reportUI:FindFirstChild("inv", true)
    local tvHasMeds = (reportUI and reportUI.Visible and invFolder and #invFolder:GetChildren() > 1)

    -- FIXED: Cari inBedPP dengan helper baru, bukan strict parent.Name check
    local inBedPP = findInBedPP_R7(minigame, currentPatient)

    if Config.ShowConsoleLogs then
        print("[R7] executeRoom7: tvHasMeds=" .. tostring(tvHasMeds)
            .. " | inBedPP=" .. tostring(inBedPP ~= nil)
            .. " | healing=" .. tostring(isR7HealingDone(minigame)))
    end

    if tvHasMeds then
        local pendingMeds = getRoom7PendingMedicines(reportUI)

        if Config.ShowConsoleLogs then
            print("[R7] pendingMeds: " .. #pendingMeds .. " — " .. table.concat(pendingMeds, ", "))
        end

        -- Anomaly kill
        if #pendingMeds > 0 and Config.AnomalyKiller and checkAnomalyStatus_Em(currentPatient) then
            setStatus("!! ANOMALI R7 — Menyiapkan racun !!", "R7")
            local wrongMedicine = findAndFetchWrongMedicine(pendingMeds, fetchItem_R7, "R7")
            if wrongMedicine then
                teleportToTarget(EmergencyCFrames[7].Step2)
                if safeEquip_R7(wrongMedicine) then
                    erMemorySet(7, currentPatient)
                    _G.AutoRoom7_LegitHealing = true
                    setStatus("!! MENYUNTIKKAN RACUN (" .. wrongMedicine .. ") !!", "R7")
                    if inBedPP then simpleInteract_R7(inBedPP, 0.25) end
                    _G.AutoRoom7_LastActionTick = tick()
                    task.wait(2)
                    setStatus("--- ANOMALI R7 HANGUS! ---", "R7")
                    clearAllMedItems()
                end
            else
                setStatus("Semua racun R7 habis stok! Tunggu...", "R7")
                task.wait(2)
            end
            return
        end

        -- Normal inject
        if #pendingMeds > 0 then
            if not inBedPP then
                -- Belum ada PP — mungkin game belum ready, tunggu sebentar
                setStatus("R7: Menunggu inject PP muncul...", "R7")
                task.wait(1); return
            end
            for _, obat in ipairs(pendingMeds) do
                local hasIt = LocalPlayer.Backpack:FindFirstChild(obat) or LocalPlayer.Character:FindFirstChild(obat)
                if not hasIt then
                    fetchItem_R7(obat, pendingMeds)
                    task.wait(0.2)
                end
                local stillHasIt = LocalPlayer.Backpack:FindFirstChild(obat) or LocalPlayer.Character:FindFirstChild(obat)
                if stillHasIt then
                    teleportToTarget(EmergencyCFrames[7].Step2)
                    if safeEquip_R7(obat) then
                        setStatus("Menyuntikkan " .. obat, "R7")
                        simpleInteract_R7(inBedPP, 0.25)
                        -- FIXED: Set LegitHealing setelah kita inject — bukan di checkRoom7Status
                        _G.AutoRoom7_LegitHealing = true
                        _G.AutoRoom7_LastActionTick = tick()
                        task.wait(Config.InjectionDelay)
                    end
                else
                    setStatus("R7: Gagal ambil " .. obat .. ", skip...", "R7")
                end
            end
        else
            -- Semua obat sudah tercentang — tunggu healing
            setStatus("Obat Tercentang, Tunggu Healing...", "R7")
            _G.AutoRoom7_LegitHealing = true
            if inBedPP then simpleInteract_R7(inBedPP, 0.25) end
            _G.AutoRoom7_LastActionTick = tick()
            task.wait(1)
        end
        return
    end

    -- ==========================================
    -- STEP 4: Collect result
    -- ==========================================
    for _, prompt in ipairs(minigame:GetDescendants()) do
        if prompt:IsA("ProximityPrompt") and prompt.Enabled then
            local actText = string.lower(prompt.ActionText or "")
            if actText:match("collect") then
                setStatus("Mengambil Hasil: Collect", "R7")
                unequipAll()
                simpleInteract_R7(prompt, 0.5, true)
                _G.AutoRoom7_LastActionTick = tick()
                task.wait(1); return
            end
        end
    end

    -- ==========================================
    -- STEP 5: Process bypass
    -- ==========================================
    local hasEarlyStep  = false
    local processPrompt = nil
    for _, prompt in ipairs(minigame:GetDescendants()) do
        if prompt:IsA("ProximityPrompt") then
            local actText = string.lower(prompt.ActionText or "")
            if actText:match("process") then processPrompt = prompt end
            if prompt.Enabled and (actText:match("prepare") or actText:match("set up")
            or actText:match("turn on") or actText:match("begin")) then
                hasEarlyStep = true
            end
        end
    end

    if hasEarlyStep and processPrompt then
        setStatus("BYPASS: Menembak Process...", "R7")
        unequipAll()
        local oldEnabled = processPrompt.Enabled
        processPrompt.Enabled = true
        simpleInteract_R7(processPrompt, 0.5, true)
        processPrompt.Enabled = oldEnabled
        _G.AutoRoom7_LastActionTick = tick()
        task.wait(1); return
    elseif processPrompt and processPrompt.Enabled then
        setStatus("Mengeksekusi Process...", "R7")
        unequipAll()
        simpleInteract_R7(processPrompt, 0.5, true)
        _G.AutoRoom7_LastActionTick = tick()
        task.wait(1); return
    end

    -- Tidak ada yang bisa dilakukan — log dan tunggu
    if Config.ShowConsoleLogs then
        -- Print semua prompt yang ada di minigame untuk debug
        local prompts = {}
        for _, pp in ipairs(minigame:GetDescendants()) do
            if pp:IsA("ProximityPrompt") then
                table.insert(prompts, (pp.Name or "?") .. "[" .. (pp.ActionText or "?") .. "|en=" .. tostring(pp.Enabled) .. "]")
            end
        end
        print("[R7] No action found. Prompts: " .. (#prompts > 0 and table.concat(prompts, ", ") or "NONE"))
    end
    setStatus("R7: Menunggu Reaksi Server...", "R7")
    task.wait(0.5)
end

