local function turboSafeEquip(itemName)
    local char    = LocalPlayer.Character
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    local hum     = char and char:FindFirstChild("Humanoid")
    if not char or not backpack or not hum then return false end
    if char:FindFirstChild(itemName) then return true end
    hum:UnequipTools()
    local t1 = 0
    while char:FindFirstChildOfClass("Tool") and t1 < 10 do task.wait(0.05); t1 = t1 + 1 end
    local tool = backpack:FindFirstChild(itemName) or char:FindFirstChild(itemName)
    if not tool then return false end
    hum:EquipTool(tool)
    local t2 = 0
    while not char:FindFirstChild(itemName) and t2 < 15 do task.wait(0.05); t2 = t2 + 1 end
    task.wait(0.1)
    return char:FindFirstChild(itemName) ~= nil
end

local function trashItem_Med(toolToTrash)
    local char = LocalPlayer.Character
    if not char then return false end
    InventoryMutex:lock("Med-trash")
    local trashPrompt = getPromptFromCache("Trash", true, nil, _G.AutoDoctor_TrashCache)
    if not trashPrompt then
        for _, desc in ipairs(workspace:GetDescendants()) do
            if desc:IsA("ProximityPrompt") then
                local actText = string.lower(desc.ActionText or "")
                local objName = string.lower(desc.Parent and desc.Parent.Name or "")
                if actText:match("trash") or actText:match("throw") or actText:match("dispose") or objName:match("trash") then
                    _G.AutoDoctor_TrashCache = desc
                    trashPrompt = desc
                    break
                end
            end
        end
    else
        _G.AutoDoctor_TrashCache = trashPrompt
    end
    if trashPrompt then
        setStatus("Membuang item (Turbo): " .. toolToTrash.Name)
        teleportToTarget(trashPrompt)
        if turboSafeEquip(toolToTrash.Name) then
            local oldReq  = trashPrompt.RequiresLineOfSight
            local oldDist = trashPrompt.MaxActivationDistance
            trashPrompt.RequiresLineOfSight = false
            trashPrompt.MaxActivationDistance = math.huge
            trashPrompt.HoldDuration = 0
            if type(fireproximityprompt) == "function" then fireproximityprompt(trashPrompt)
            else trashPrompt:InputHoldBegan() task.wait(0.05) trashPrompt:InputHoldEnded() end
            trashPrompt.RequiresLineOfSight   = oldReq
            trashPrompt.MaxActivationDistance = oldDist
            _G.AutoDoctor_LastActionTick = tick()
            task.wait(0.1)
            InventoryMutex:unlock("Med-trash")
            return true
        end
    end
    setStatus("GAGAL: Tempat sampah tidak ditemukan!")
    InventoryMutex:unlock("Med-trash")
    return false
end

local function fetchItem_Med(targetName, pendingMedsList)
    local char = LocalPlayer.Character
    if not char then return false end
    InventoryMutex:lock("Med-fetch")
    setStatus("Mengambil (Insta-Fetch): " .. targetName)
    local totalAmount, currentItems = checkTotalInventory()
    if totalAmount >= Config.MaxInventory then
        local itemToThrowAway = nil
        if pendingMedsList then
            local reqCounts = {}
            for _, o in ipairs(pendingMedsList) do reqCounts[o] = (reqCounts[o] or 0) + 1 end
            local haveCounts = {}
            for _, item in ipairs(currentItems) do
                haveCounts[item.Name] = (haveCounts[item.Name] or 0) + 1
            end
            for _, item in ipairs(currentItems) do
                local needed = reqCounts[item.Name] or 0
                local have   = haveCounts[item.Name] or 0
                if needed == 0 or have > needed then
                    itemToThrowAway = item; break
                end
            end
        end
        if not itemToThrowAway then itemToThrowAway = currentItems[1] end
        local trashed = trashItem_Med(itemToThrowAway)
        if not trashed then InventoryMutex:unlock("Med-fetch"); return false end
    end
    local promptToUse = getPromptFromCache(targetName, false, _G.AutoDoctor_ItemCache, nil)
    if promptToUse then
        unequipAll()
        teleportToTarget(promptToUse)
        local oldReq  = promptToUse.RequiresLineOfSight
        local oldDist = promptToUse.MaxActivationDistance
        local oldHold = promptToUse.HoldDuration
        promptToUse.RequiresLineOfSight   = false
        promptToUse.MaxActivationDistance = math.huge
        promptToUse.HoldDuration          = 0
        local gotItem = false
        for retry = 1, 15 do
            if type(fireproximityprompt) == "function" then fireproximityprompt(promptToUse)
            else promptToUse:InputHoldBegan() task.wait(0.05) promptToUse:InputHoldEnded() end
            task.wait(0.1)
            if LocalPlayer.Backpack:FindFirstChild(targetName) or LocalPlayer.Character:FindFirstChild(targetName) then
                gotItem = true; break
            end
        end
        promptToUse.RequiresLineOfSight   = oldReq
        promptToUse.MaxActivationDistance = oldDist
        promptToUse.HoldDuration          = oldHold
        if gotItem then
            setStatus("Berhasil Mengambil: " .. targetName)
            _G.AutoDoctor_LastActionTick = tick()
            InventoryMutex:unlock("Med-fetch")
            return true
        else
            setStatus("GAGAL Mengambil: " .. targetName)
            InventoryMutex:unlock("Med-fetch")
            return false
        end
    end
    setStatus("GAGAL: " .. targetName .. " tidak ditemukan.")
    InventoryMutex:unlock("Med-fetch")
    return false
end

local function simpleInteract_Med(prompt, customHold, autoLock)
    if prompt and prompt:IsA("ProximityPrompt") then
        if autoLock then teleportToTarget(prompt) end
        local oldReq  = prompt.RequiresLineOfSight
        local oldDist = prompt.MaxActivationDistance
        prompt.RequiresLineOfSight   = false
        prompt.MaxActivationDistance = math.huge
        if type(fireproximityprompt) == "function" then fireproximityprompt(prompt)
        else
            prompt:InputHoldBegan()
            task.wait(customHold or prompt.HoldDuration or 0.1)
            prompt:InputHoldEnded()
        end
        _G.AutoDoctor_LastActionTick = tick()
        prompt.RequiresLineOfSight   = oldReq
        prompt.MaxActivationDistance = oldDist
        task.wait(0.1)
    end
    return true
end

