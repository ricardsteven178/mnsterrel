local function getPendingMeds_R6(tvUI)
    local pending = {}
    if not tvUI then return pending end
    local invFolder = tvUI:FindFirstChild("inv", true)
    if not invFolder then return pending end
    for _, req in ipairs(invFolder:GetChildren()) do
        if not req:IsA("UIListLayout") and table.find(ItemList, req.Name) then
            local chk = req:FindFirstChild("check")
            if not chk or not chk.Visible then table.insert(pending, req.Name) end
        end
    end
    return pending
end

local function isR6ReallyActive()
    local path     = getEmergencyRoom(6)
    local minigame = path and path:FindFirstChild("Minigame")
    if not path or not minigame then return false, nil, nil end
    if isHealingDone_R6(minigame) then return false, path, minigame end
    local patNPC, patPP = getPatientInEmergency(6, EmergencyCFrames[6].Patient, EmergencyCFrames[6].Radius)
    if patNPC then return true, path, minigame end
    local tvScreen = minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen", true)
    local tvUI     = tvScreen and tvScreen:FindFirstChild("UI")
    local pending  = getPendingMeds_R6(tvUI)
    if #pending > 0 then return true, path, minigame end
    for _, pp in ipairs(minigame:GetDescendants()) do
        if pp:IsA("ProximityPrompt") and pp.Enabled then
            local txt = string.lower(pp.ActionText or "")
            if txt:match("collect") then return true, path, minigame end
        end
    end
    return false, path, minigame
end

local function executeRoom6()
    local success, err = pcall(function()
        local isActive, path, minigame = isR6ReallyActive()
        if not isActive then
            if not _G.Room6_IsIdle then unequipAll(); teleportToIdle(); _G.Room6_IsIdle = true end
            setStatus("Idle (Standby R6 — menunggu pasien fisik)...", "R6")
            task.wait(0.5)
            return
        end
        local currentNPC_R6, _ = getPatientInEmergency(6, EmergencyCFrames[6].Patient, EmergencyCFrames[6].Radius)
        if erMemoryCheck(6, currentNPC_R6) then
            if not _G.Room6_IsIdle then unequipAll(); teleportToIdle(); _G.Room6_IsIdle = true end
            setStatus("R6: Menunggu pasien lama pergi...", "R6")
            task.wait(1)
            return
        end
        _G.Room6_IsIdle = false
        setStatus("R6 Aktif! Pasien terdeteksi, memulai treatment...", "R6")
        local char = LocalPlayer.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if root then root.CFrame = EmergencyCFrames[6].Room; root.Velocity = Vector3.zero; task.wait(0.3) end
        local isDone           = false
        local lastProgressTime = tick()
        local lastPendingCount = -1
        local emptyCounter     = 0
        local MAX_STUCK        = Config.StuckTimeout

        while not isDone and autoEnabled_R6 do
            task.wait(0.3)
            local activeNow, _, _ = isR6ReallyActive()
            if not activeNow then
                emptyCounter = emptyCounter + 1
                if emptyCounter >= 3 then
                    setStatus("✅ R6 Clear. Kembali Idle...", "R6")
                    erMemorySet(6, nil)
                    isDone = true; break
                end
                continue
            else
                emptyCounter = 0
            end
            if isHealingDone_R6(minigame) then
                setStatus("✅ R6 Healing selesai! Kembali Idle...", "R6")
                local doneNPC, _ = getPatientInEmergency(6, EmergencyCFrames[6].Patient, EmergencyCFrames[6].Radius)
                erMemorySet(6, doneNPC)
                clearAllMedItems()
                isDone = true; break
            end
            if tick() - lastProgressTime >= MAX_STUCK then
                setStatus("⚠️ R6 Stuck! Force reset...", "R6")
                forceFailMinigame_R6()
                isDone = true; break
            end
            local patNPC, patPP = getPatientInEmergency(6, EmergencyCFrames[6].Patient, EmergencyCFrames[6].Radius)
            local tvScreen      = minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen", true)
            local tvUI          = tvScreen and tvScreen:FindFirstChild("UI")
            local pending       = getPendingMeds_R6(tvUI)
            if #pending > 0 then
                if #pending ~= lastPendingCount then
                    lastPendingCount = #pending
                    lastProgressTime = tick()
                end
                if not patPP then
                    setStatus("Menunggu NPC siap disuntik...", "R6")
                    continue
                end
                if Config.AnomalyKiller and checkAnomalyStatus_Em(patNPC) then
                    local hasBurnsPP = false
                    for _, pp in ipairs(patNPC:GetDescendants()) do
                        if pp:IsA("ProximityPrompt") and pp.Enabled then
                            local ppName = string.lower(pp.Name or "")
                            local ppAct  = string.lower(pp.ActionText or "")
                            if ppName == "firepp" or ppAct:match("burns") then hasBurnsPP = true; break end
                        end
                    end
                    if hasBurnsPP then
                        setStatus("Anomali R6 terbakar — Ointment dulu!", "R6")
                        local hasOintment = LocalPlayer.Backpack:FindFirstChild("Ointment") or LocalPlayer.Character:FindFirstChild("Ointment")
                        if not hasOintment then fetchItem_R6("Ointment", {"Ointment"}) end
                        if root then root.CFrame = EmergencyCFrames[6].Room; root.Velocity = Vector3.zero; task.wait(0.2) end
                        local toolO = LocalPlayer.Backpack:FindFirstChild("Ointment") or LocalPlayer.Character:FindFirstChild("Ointment")
                        local hum6b = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
                        if toolO and hum6b then unequipAll(); task.wait(0.1); hum6b:EquipTool(toolO) end
                        task.wait(0.2)
                        local _, freshPP6b = getPatientInEmergency(6, EmergencyCFrames[6].Patient, EmergencyCFrames[6].Radius)
                        interact_R6(freshPP6b or patPP, 0.25)
                        lastProgressTime = tick()
                        continue
                    end

                    setStatus("!! ANOMALI R6 — Menyiapkan racun !!", "R6")
                    local wrongMedicine = findAndFetchWrongMedicine(pending, fetchItem_R6, "R6")
                    if wrongMedicine then
                        -- Anchor ke room position dulu
                        if root then
                            root.CFrame = EmergencyCFrames[6].Room
                            root.Velocity = Vector3.zero
                            root.AssemblyLinearVelocity = Vector3.zero
                            task.wait(0.3)
                        end

                        -- SafeEquip: tunggu tool benar-benar equipped
                        local char6   = LocalPlayer.Character
                        local hum6    = char6 and char6:FindFirstChild("Humanoid")
                        local tool6   = LocalPlayer.Backpack:FindFirstChild(wrongMedicine) or char6:FindFirstChild(wrongMedicine)
                        local equipped = false
                        if hum6 and tool6 then
                            unequipAll(); task.wait(0.15)
                            hum6:EquipTool(tool6)
                            -- Tunggu max 1.5s sampai tool benar-benar di tangan
                            local waitEquip = 0
                            while waitEquip < 30 do
                                if char6:FindFirstChild(wrongMedicine) then equipped = true; break end
                                task.wait(0.05); waitEquip = waitEquip + 1
                            end
                        end

                        if not equipped then
                            setStatus("GAGAL equip racun R6: " .. wrongMedicine .. " — retry...", "R6")
                            task.wait(1)
                        else
                            task.wait(0.15)
                            -- Scan PP dari Patient position (bukan Room position)
                            local _, freshPP6 = getPatientInEmergency(6, EmergencyCFrames[6].Patient, EmergencyCFrames[6].Radius)
                            local injectPP = freshPP6 or patPP

                            if not injectPP then
                                -- Last resort: scan seluruh minigame descendants
                                for _, desc in ipairs(minigame:GetDescendants()) do
                                    if desc:IsA("ProximityPrompt") then
                                        local act = string.lower(desc.ActionText or "")
                                        if act:match("inject") or act:match("treat") or act:match("apply") or desc.Name:lower() == "pp" then
                                            injectPP = desc; break
                                        end
                                    end
                                end
                            end

                            if injectPP then
                                erMemorySet(6, patNPC)
                                setStatus("MENYUNTIKKAN RACUN R6: " .. wrongMedicine, "R6")
                                interact_R6(injectPP, 0.25)
                                task.wait(0.5)
                                setStatus("--- ANOMALI R6 HANGUS! ---", "R6")
                                clearAllMedItems()
                                lastProgressTime = tick()
                                isDone = true; break
                            else
                                setStatus("GAGAL: Inject PP R6 tidak ditemukan!", "R6")
                                task.wait(1)
                            end
                        end
                    else
                        setStatus("Semua racun R6 habis stok! Tunggu...", "R6")
                        task.wait(2)
                    end

                else
                    for _, obat in ipairs(pending) do
                        local hasItem = LocalPlayer.Backpack:FindFirstChild(obat) or (LocalPlayer.Character and LocalPlayer.Character:FindFirstChild(obat))
                        if not hasItem then
                            fetchItem_R6(obat, pending)
                            if root then root.CFrame = EmergencyCFrames[6].Room; root.Velocity = Vector3.zero; task.wait(0.2) end
                        end
                        local tool = LocalPlayer.Backpack:FindFirstChild(obat)
                        local hum  = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
                        if tool and hum then unequipAll(); task.wait(0.1); hum:EquipTool(tool) end
                        task.wait(0.2)
                        local _, freshPP = getPatientInEmergency(6, EmergencyCFrames[6].Patient, EmergencyCFrames[6].Radius)
                        setStatus("Menyuntikkan: " .. obat, "R6")
                        interact_R6(freshPP or patPP, 0.25)
                        lastProgressTime = tick()
                    end
                    task.wait(0.5)
                    continue
                end
            end
            local collected = false
            for _, pp in ipairs(minigame:GetDescendants()) do
                if pp:IsA("ProximityPrompt") and pp.Enabled then
                    local txt = string.lower(pp.ActionText or "")
                    if txt:match("collect") then
                        setStatus("Mengambil Hasil (Collect)...", "R6")
                        if root then root.CFrame = EmergencyCFrames[6].Room; root.Velocity = Vector3.zero; task.wait(0.1) end
                        interact_R6(pp, 0.5)
                        lastProgressTime = tick()
                        collected = true
                        task.wait(0.5)
                        break
                    end
                end
            end
            if collected then continue end
            local monitor = minigame:FindFirstChild("Monitor")
            if monitor then
                for _, pp in ipairs(monitor:GetDescendants()) do
                    if pp:IsA("ProximityPrompt") and string.lower(pp.ActionText or ""):match("process") then
                        setStatus("BYPASS: Process Instan...", "R6")
                        if root then root.CFrame = EmergencyCFrames[6].Room; root.Velocity = Vector3.zero; task.wait(0.1) end
                        interact_R6(pp, 0.25)
                        lastProgressTime = tick()
                        task.wait(0.5)
                        break
                    end
                end
            end
            setStatus("R6: Menunggu aksi berikutnya...", "R6")
        end
