    end
end

local function getPendingMedicines(tvUI)
    local pending = {}
    if not tvUI then return pending end
    local invFolder = tvUI:FindFirstChild("inv", true)
    if not invFolder then return pending end
    for _, itemReq in ipairs(invFolder:GetChildren()) do
        if table.find(ItemList, itemReq.Name) then
            local checkMark = itemReq:FindFirstChild("check")
            if not checkMark or (checkMark and checkMark.Visible == false) then
                table.insert(pending, itemReq.Name)
            end
        end
    end
    return pending
end

local function getPromptsNearBed(roomPath, bedPart)
    local prompts = {}
    if not roomPath or not bedPart then return prompts end
    local minigame = roomPath:FindFirstChild("Minigame")
    if minigame then
        for _, desc in ipairs(minigame:GetDescendants()) do
            if desc:IsA("ProximityPrompt") and desc.Enabled then table.insert(prompts, desc) end
        end
    end
    if workspace:FindFirstChild("NPCs") then
        for _, npc in ipairs(workspace.NPCs:GetChildren()) do
            local p = npc.PrimaryPart or npc:FindFirstChildWhichIsA("BasePart")
            if p and (p.Position - bedPart.Position).Magnitude <= Config.PatientBedRadius then
                for _, desc in ipairs(npc:GetDescendants()) do
                    if desc:IsA("ProximityPrompt") and desc.Enabled then table.insert(prompts, desc) end
                end
            end
        end
    end
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local p = player.Character.PrimaryPart or player.Character:FindFirstChildWhichIsA("BasePart")
            if p and (p.Position - bedPart.Position).Magnitude <= Config.PatientBedRadius then
                for _, desc in ipairs(player.Character:GetDescendants()) do
                    if desc:IsA("ProximityPrompt") and desc.Enabled then table.insert(prompts, desc) end
                end
            end
        end
    end
    return prompts
end

local function isPatientReady(roomPath, bedPart)
    local minigame = roomPath:FindFirstChild("Minigame")
    local tvUI     = minigame and minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen", true)
    local pending  = getPendingMedicines(tvUI)
    if #pending > 0 then return true, "TV Aktif (Butuh Obat)" end
    local prompts = getPromptsNearBed(roomPath, bedPart)
    for _, desc in ipairs(prompts) do
        local actText = string.lower(desc.ActionText or "")
        local name    = string.lower(desc.Name or "")
        if actText:match("inspect") then
        elseif actText:match("dna") or name:match("dna") then return true, "Tombol DNA"
        elseif actText:match("burns") or name == "firepp" then return true, "Tombol Luka Bakar"
        elseif actText:match("analyze") or actText:match("process") or name:match("analyze") then return true, "Mesin Lab"
        end
    end
    return false, "Kosong/Healing"
end

local function getPatientInRoom_Med(roomNum, roomPath)
    local bedPart  = roomPath and roomPath:FindFirstChild("Minigame") and roomPath.Minigame:FindFirstChild("Bed") and roomPath.Minigame.Bed:FindFirstChild("InBed")
    local centerPos = (bedPart and bedPart.Position) or (RoomCFrames[roomNum] and RoomCFrames[roomNum].Position)
    if not centerPos and roomPath and roomPath.PrimaryPart then centerPos = roomPath.PrimaryPart.Position end
    if not centerPos then return nil end
    local radius = Config.PatientBedRadius
    local function checkNPC(obj)
        if Players:GetPlayerFromCharacter(obj) then return nil end
        if not obj:IsA("Model") then return nil end
        local part = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
        if not part or (part.Position - centerPos).Magnitude > radius then return nil end
        for _, pp in ipairs(obj:GetDescendants()) do
            if pp:IsA("ProximityPrompt") then
                local txt  = string.lower(pp.ActionText or "")
                local name = string.lower(pp.Name or "")
                if txt:match("dna") or txt:match("treat") or name == "firepp"
                or txt:match("burns") or txt:match("inject") then
                    return obj
                end
            end
        end
        if obj:FindFirstChildOfClass("Humanoid") then return obj end
        return nil
    end
    if workspace:FindFirstChild("NPCs") then
        for _, npc in ipairs(workspace.NPCs:GetChildren()) do
            local found = checkNPC(npc)
            if found then return found end
        end
    end
    for _, obj in ipairs(workspace:GetChildren()) do
        if obj:IsA("Model") and obj ~= LocalPlayer.Character and obj.Name ~= "Rooms" and obj.Name ~= "Misc" then
            local found = checkNPC(obj)
            if found then return found end
        end
    end
    return nil
end

local function isRoomDone_Med(roomNum, minigame, roomPath, bedPart, currentPatient)
    if not minigame then return false end
    if roomPath and bedPart then
        local ready, reason = isPatientReady(roomPath, bedPart)
        if ready and reason == "Tombol Luka Bakar" then return false end
    end
    if currentPatient then
        if currentPatient:FindFirstChild("PE", true)   then return false end
        if currentPatient:FindFirstChild("Heal", true) then return true end
    end
    local tv     = minigame:FindFirstChild("TV")
    local screen = tv and tv:FindFirstChild("Screen")
    local ui     = screen and screen:FindFirstChild("UI")
    if ui and ui:IsA("SurfaceGui") and ui.Enabled and ui:FindFirstChild("inv", true) then
        local invFolder  = ui:FindFirstChild("inv", true)
        local totalItems = 0
        for _, itemReq in ipairs(invFolder:GetChildren()) do
            if table.find(ItemList, itemReq.Name) then totalItems = totalItems + 1 end
        end
        local pending = getPendingMedicines(ui)
        if totalItems > 0 and #pending == 0 then return true end
    end
    return false
end

local function checkAnomalyStatus_Med(bedPart, specificNPC)
    if specificNPC then
        local attr = specificNPC:GetAttributes()
        if attr.Skinwalker or attr.SkinwalkerEasy or attr.PenaltyWhenLettingIn
        or attr.PhotoEffect == "CursedPhoto" or attr.PhotoEffect2 == "CursedPhoto" then
            return true
        end
        return false
    end
    if not bedPart then return false end
    if workspace:FindFirstChild("NPCs") then
        for _, npc in ipairs(workspace.NPCs:GetChildren()) do
            local p = npc.PrimaryPart or npc:FindFirstChildWhichIsA("BasePart")
            if p and (p.Position - bedPart.Position).Magnitude <= Config.PatientBedRadius then
                local attr = npc:GetAttributes()
                if attr.Skinwalker or attr.SkinwalkerEasy or attr.PenaltyWhenLettingIn
                or attr.PhotoEffect == "CursedPhoto" or attr.PhotoEffect2 == "CursedPhoto" then
                    return true
                end
            end
        end
    end
    return false
end

local function findActiveRoom_Med()
    local roomsFolder   = workspace:FindFirstChild("Rooms")
    local medicalFolder = roomsFolder and roomsFolder:FindFirstChild("Medical")
    if not medicalFolder then return nil, nil end

    local lightRedRooms = {}

    for i = 1, Config.MaxRooms do
        local room     = medicalFolder:FindFirstChild("Room" .. i)
        if room then
            local minigame = room:FindFirstChild("Minigame")
            local bed      = minigame and minigame:FindFirstChild("Bed") and minigame.Bed:FindFirstChild("InBed")
            local currentPatient = getPatientInRoom_Med(i, room)
            local mem = _G.AutoDoctor_RoomMemory[i]

            -- ==========================================
            -- FIXED: Memory validation — handle semua tipe
            -- Sebelumnya "JobDone" string tidak pernah di-clear
            -- kalau NPC baru dateng ke room yang sama
            -- ==========================================
            if mem then
                if not currentPatient then
                    -- Room kosong, clear memory
                    _G.AutoDoctor_RoomMemory[i] = nil
                elseif mem == "JobDone" then
                    -- *** KEY FIX: NPC baru datang setelah pasien lama selesai
                    -- Clear JobDone memory supaya room bisa diproses lagi
                    if Config.ShowConsoleLogs then
                        print("[Scan] Room" .. i .. ": Clear JobDone memory — NPC baru terdeteksi")
                    end
                    _G.AutoDoctor_RoomMemory[i] = nil
                elseif typeof(mem) == "Instance" then
                    if currentPatient ~= mem then
                        -- NPC berbeda, clear
                        _G.AutoDoctor_RoomMemory[i] = nil
                    elseif currentPatient:FindFirstChild("PE", true) then
                        -- NPC sama tapi ada PE (bisa diobati lagi)
                        _G.AutoDoctor_RoomMemory[i] = nil
                    end
                    -- else: NPC sama, tidak ada PE — memory valid, skip room
                else
                    -- Unknown memory type, clear aja
                    _G.AutoDoctor_RoomMemory[i] = nil
                end
            end

            local isBlacklisted = BuggedRoomBlacklist[i] and (tick() - BuggedRoomBlacklist[i] < Config.BlacklistDuration)
            if isBlacklisted and currentPatient then
                BuggedRoomBlacklist[i] = nil
                isBlacklisted = false
            end

            -- Diagnostic: log kenapa room di-skip (hanya saat idle stuck)
            if isBlacklisted then
                if Config.ShowConsoleLogs then
                    print("[Scan] Room" .. i .. ": SKIP — blacklist (sisa " .. math.floor(Config.BlacklistDuration - (tick() - BuggedRoomBlacklist[i])) .. "s)")
                end
                continue
            end
            if _G.AutoDoctor_RoomMemory[i] then
                if Config.ShowConsoleLogs then
                    local memVal = _G.AutoDoctor_RoomMemory[i]
                    print("[Scan] Room" .. i .. ": SKIP — memory=" .. tostring(typeof(memVal) == "Instance" and memVal.Name or memVal))
                end
                continue
            end

            if currentPatient then
                local ready, reason = isPatientReady(room, bed)
                if ready then
                    if Config.ShowConsoleLogs then
                        print("[Scan] Room" .. i .. ": AKTIF — " .. tostring(reason))
                    end
                    return room, i
                else
                    if Config.ShowConsoleLogs then
                        print("[Scan] Room" .. i .. ": NPC ada tapi not ready — " .. tostring(reason))
                    end
                end
            end
            local tvUI    = minigame and minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen", true)
            local pending = getPendingMedicines(tvUI)
            if #pending > 0 then
                if Config.ShowConsoleLogs then
                    print("[Scan] Room" .. i .. ": AKTIF — TV pending " .. #pending .. " obat")
                end
                return room, i
            end
            local signLight  = room:FindFirstChild("MainSign") and room.MainSign:FindFirstChild("Light")
            local isLightRed = signLight and (signLight.BrickColor.Name == "Crimson" or signLight.Color == Color3.fromRGB(165, 0, 0))
            if isLightRed and not currentPatient then
                table.insert(lightRedRooms, i)
            end
        end
    end

    if Config.ShowConsoleLogs and #lightRedRooms > 0 then
        print("[Scan] Lampu merah (tunggu pasien): Room " .. table.concat(lightRedRooms, ", "))
    end

    return nil, nil
end

