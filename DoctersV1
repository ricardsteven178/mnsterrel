-- FIXED: Full state flush helper
-- Dipakai oleh idle timeout dan watchdog
-- ==========================================
local function fullStateFlush(reason)
    if Config.ShowConsoleLogs then
        print("[FullFlush] Triggered: " .. tostring(reason))
    end
    -- Kill worker dulu sebelum reset state
    masterRunning = false
    if masterWorker then
        pcall(function() task.cancel(masterWorker) end)
        masterWorker = nil
    end
    task.wait(0.2)

    -- Reset semua state flags
    BuggedRoomBlacklist          = {}
    _G.AutoDoctor_RoomMemory     = {}
    erMemoryReset()
    _G.AutoDoctor_IsIdle         = false
    _G.Room6_IsIdle              = false
    _G.AutoRoom7_IsIdle          = false
    isBotIdle_R8                 = false
    _G.AutoRoom7_BlacklistTime   = 0
    _G.IdleStartTick             = nil
    isBusy_Medical               = false
    InventoryMutex._locked       = false
    InventoryMutex._owner        = nil
    masterLastTick               = tick()

    -- Teleport ke idle position dulu
    teleportToIdle()
    task.wait(0.3)
end

local function masterCycle()
    local activeShift = getShiftText() or "Shift Aktif"
    masterLastTick    = tick()

    local fireNPC, firePP = getFireEmergency_Med()
    if fireNPC then
        _G.AutoDoctor_IsIdle = false; _G.IdleStartTick = nil
        setStatus("! P1: Memadamkan Pasien Terbakar !")
        unequipAll()
        local targetNode = fireNPC.PrimaryPart or fireNPC:FindFirstChildWhichIsA("BasePart")
        simpleInteract_Med(firePP, 3.2, targetNode)
        task.wait(1.5)
        return
    end

    local faintedPart, carryPP = getFaintedPatient_Med()
    if faintedPart then
        _G.AutoDoctor_IsIdle = false; _G.IdleStartTick = nil
        setStatus("! P2: Mengurus Pasien Pingsan !")
        pcall(function() processFaintedPatient_Med(faintedPart, carryPP, activeShift) end)
        return
    end
    local placePrompt, targetRoomName, targetRoomNum, targetRoomPath = getPlacePatientPrompt_Med()
    if placePrompt then
        _G.AutoDoctor_IsIdle = false; _G.IdleStartTick = nil
        setStatus("P2: Menaruh pasien ke " .. tostring(targetRoomName) .. "...")
        unequipAll()
        if targetRoomNum and targetRoomPath then
            teleportToRoomCenter(targetRoomNum, targetRoomPath)
            task.wait(0.3)
        else
            teleportToTarget(placePrompt)
            task.wait(0.2)
        end
        for placeTry = 1, 5 do
            simpleInteract_Med(placePrompt, 1, false)
            task.wait(0.8)
            if not placePrompt.Parent or not placePrompt.Enabled then
                setStatus("✅ Pasien berhasil ditempatkan di " .. tostring(targetRoomName))
                break
            end
            teleportToTarget(placePrompt)
            task.wait(0.2)
        end
        return
    end

    local erRoom = getActiveEmergencyRoom()
    if erRoom == 6 then
        _G.AutoDoctor_IsIdle = false; _G.IdleStartTick = nil
        pcall(executeRoom6)
        return
    end
    if erRoom == 7 then
        _G.AutoDoctor_IsIdle = false; _G.IdleStartTick = nil
        local room7, _ = checkRoom7Status()
        if room7 then pcall(function() executeRoom7(room7, activeShift) end) end
        return
    end
    if erRoom == 8 then
        _G.AutoDoctor_IsIdle = false; _G.IdleStartTick = nil
        pcall(botCycleRoom8)
        return
    end

    if autoScanEnabled then
        local room, roomNum = findActiveRoom_Med()
        if room and roomNum then
            _G.AutoDoctor_IsIdle = false; _G.IdleStartTick = nil
            pcall(function() executeTreatmentCore_Med(room, roomNum, activeShift) end)
            return
        end
    end

    local anyOn = autoScanEnabled or autoEnabled_R6 or isAutoPlaying_R7 or autoEnabled_R8
    if anyOn then
        if not _G.AutoDoctor_IsIdle then
            unequipAll(); teleportToIdle()
            _G.AutoDoctor_IsIdle  = true
            _G.Room6_IsIdle       = true
            _G.AutoRoom7_IsIdle   = true
            isBotIdle_R8          = true
            _G.IdleStartTick      = tick()
        end

        -- ==========================================
        -- FIXED: Idle timeout — full flush + clean restart
        -- ==========================================
        if Config.IdleTimeout > 0 and _G.IdleStartTick then
            local idleDuration = tick() - _G.IdleStartTick
            if idleDuration >= Config.IdleTimeout then
                setStatus("Idle timeout (" .. Config.IdleTimeout .. "s) — paksa re-scan semua room...")
                fullStateFlush("IdleTimeout")
                task.wait(0.5)
                -- Restart worker dengan state bersih
                local anyEnabled = autoScanEnabled or autoEnabled_R6 or isAutoPlaying_R7 or autoEnabled_R8
                if anyEnabled then
                    masterRunning = true
                    masterWorker  = task.spawn(function()
                        while masterRunning do
                            local ok, err = pcall(masterCycle)
                            if not ok then
                                warn("[Master] Error setelah flush: " .. tostring(err))
                                task.wait(2)
                            end
                            task.wait(0.1)
                        end
                    end)
                end
                return
            end
        end

        setStatus("Idle — memantau semua room...")
    end
    task.wait(Config.ScanDelay)
end

local function startMasterWorker()
    if masterWorker then
        pcall(function() task.cancel(masterWorker) end)
        masterWorker = nil
    end
    masterRunning = true
    masterWorker  = task.spawn(function()
        while masterRunning do
            local anyEnabled = autoScanEnabled or autoEnabled_R6 or isAutoPlaying_R7 or autoEnabled_R8
            if anyEnabled then
                local ok, err = pcall(masterCycle)
                if not ok then
                    warn("[Master] Error: " .. tostring(err))
                    task.wait(2)
                end
            else
                task.wait(0.5)
            end
            task.wait(0.1)
        end
    end)
end

local function stopMasterWorker()
    masterRunning = false
    if masterWorker then
        pcall(function() task.cancel(masterWorker) end)
        masterWorker = nil
    end
end

local masterWatchdog = nil
local function startMasterWatchdog()
    if masterWatchdog then
        pcall(function() task.cancel(masterWatchdog) end)
        masterWatchdog = nil
    end
    local lastShift_w      = getShiftText()
    local lastShiftNum_w   = getShiftNumber()
    local lastShiftChangeTick = tick()
    local idleWithNPCStart    = nil

    masterWatchdog = task.spawn(function()
        while true do
            task.wait(1)

            -- Jangan watchdog kalau tidak ada yang enabled
            local anyEnabled = autoScanEnabled or autoEnabled_R6 or isAutoPlaying_R7 or autoEnabled_R8
            if not anyEnabled then continue end

            local currentShift    = getShiftText()
            local currentShiftNum = getShiftNumber()

            local isShiftChanged = (currentShift ~= lastShift_w
                and currentShift ~= nil and lastShift_w ~= nil
                and currentShift ~= "Shift Aktif")

            if isShiftChanged then
                setStatus("Shift Berganti ke " .. tostring(currentShift) .. "! Reset inventory & memory...")
                Config.MaxInventory      = 5
                idleWithNPCStart         = nil
                fullStateFlush("ShiftChange")
                lastShift_w           = currentShift
                lastShiftNum_w        = currentShiftNum
                lastShiftChangeTick   = tick()
                task.wait(2)
                startMasterWorker()
                continue
            end

            -- ==========================================
            -- FIXED: Hard stuck detection — full flush + clean restart
            -- ==========================================
            local isHardStuck = masterRunning and (tick() - masterLastTick > Config.GlobalStuckTimeout)
            if isHardStuck then
                setStatus("MASTER STUCK! Hard-Reset...")
                idleWithNPCStart = nil
                fullStateFlush("HardStuck")
                task.wait(2)
                startMasterWorker()
                continue
            end

            -- ==========================================
            -- FIXED: Idle + NPC terdeteksi watchdog
            -- Kalau idle tapi ada NPC, flush state dan restart bersih
            -- ==========================================
            if _G.AutoDoctor_IsIdle then
                local hasNPCInRadar = false
                if workspace:FindFirstChild("NPCs") then
                    for _, npc in ipairs(workspace.NPCs:GetChildren()) do
                        local p = npc.PrimaryPart or npc:FindFirstChildWhichIsA("BasePart")
                        if not p then continue end
                        local roomsFolder   = workspace:FindFirstChild("Rooms")
                        local medicalFolder = roomsFolder and roomsFolder:FindFirstChild("Medical")
                        if medicalFolder and autoScanEnabled then
                            for i = 1, Config.MaxRooms do
                                local room = medicalFolder:FindFirstChild("Room" .. i)
                                local bed  = room and room:FindFirstChild("Minigame") and room.Minigame:FindFirstChild("Bed") and room.Minigame.Bed:FindFirstChild("InBed")
                                local center = (bed and bed.Position) or (RoomCFrames[i] and RoomCFrames[i].Position)
                                if center and (p.Position - center).Magnitude <= Config.PatientBedRadius then
                                    -- Skip kalau room masih di memory atau blacklist
                                    local inMem   = _G.AutoDoctor_RoomMemory[i] ~= nil
                                    local inBlack = BuggedRoomBlacklist[i] and (tick() - BuggedRoomBlacklist[i] < Config.BlacklistDuration)
                                    if not inMem and not inBlack then
                                        hasNPCInRadar = true; break
                                    end
                                end
                            end
                        end
                        if hasNPCInRadar then break end
                        if autoEnabled_R6 and (p.Position - EmergencyCFrames[6].Patient.Position).Magnitude <= EmergencyCFrames[6].Radius then
                            if not erMemoryCheck(6, npc) then hasNPCInRadar = true; break end
                        end
                        if isAutoPlaying_R7 and (p.Position - EmergencyCFrames[7].Step2.Position).Magnitude <= EmergencyCFrames[7].Radius then
                            if not erMemoryCheck(7, npc) then hasNPCInRadar = true; break end
                        end
                        if autoEnabled_R8 and (p.Position - EmergencyCFrames[8].Bed.Position).Magnitude <= EmergencyCFrames[8].Radius + 10 then
                            if not erMemoryCheck(8, npc) then hasNPCInRadar = true; break end
                        end
                    end
                end

                if hasNPCInRadar then
                    if not idleWithNPCStart then
                        idleWithNPCStart = tick()
                    elseif tick() - idleWithNPCStart >= 15 then
                        -- FIXED: 15 detik cukup — kalau lebih lama dari itu berarti memang stuck
                        setStatus("⚠️ Idle 15s tapi ada NPC valid! Full flush & restart...")
                        idleWithNPCStart = nil
                        fullStateFlush("IdleWithNPC")
                        task.wait(1)
                        startMasterWorker()
                    end
                else
                    idleWithNPCStart = nil
                end
            else
                idleWithNPCStart = nil
            end

            if currentShift then lastShift_w = currentShift end
            if currentShiftNum then lastShiftNum_w = currentShiftNum end
        end
    end)
end

