    local t2 = 0
    while not char:FindFirstChild(itemName) and t2 < 15 do task.wait(0.05); t2 = t2 + 1 end
    task.wait(0.5)
    return char:FindFirstChild(itemName) ~= nil
end

local function simpleInteract_R7(prompt, customHold, autoLock)
    if prompt and prompt:IsA("ProximityPrompt") then
        if autoLock then teleportToTarget(prompt) end
        local oldReq  = prompt.RequiresLineOfSight
        local oldDist = prompt.MaxActivationDistance
        prompt.RequiresLineOfSight   = false
        prompt.MaxActivationDistance = math.huge
        if type(fireproximityprompt) == "function" then fireproximityprompt(prompt, 1, true)
        else prompt:InputHoldBegan() task.wait(customHold or prompt.HoldDuration or 0.25) prompt:InputHoldEnded() end
        _G.AutoRoom7_LastActionTick  = tick()
        prompt.RequiresLineOfSight   = oldReq
        prompt.MaxActivationDistance = oldDist
        task.wait(0.2)
    end
end

local function fetchItem_R7(targetName, pendingMedsList)
    InventoryMutex:lock("R7-fetch")
    setStatus("Mengambil " .. targetName .. "...", "R7")
    local totalAmount, currentItems = checkTotalInventory()
    if totalAmount >= Config.MaxInventory then
        local itemToThrowAway = nil
        if pendingMedsList then
            local reqCounts = {}
            for _, o in ipairs(pendingMedsList) do reqCounts[o] = (reqCounts[o] or 0) + 1 end
            local haveCounts = {}
            for _, item in ipairs(currentItems) do haveCounts[item.Name] = (haveCounts[item.Name] or 0) + 1 end
            for _, item in ipairs(currentItems) do
                local needed = reqCounts[item.Name] or 0
                local have   = haveCounts[item.Name] or 0
                if needed == 0 or have > needed then itemToThrowAway = item; break end
            end
        end
        if not itemToThrowAway then itemToThrowAway = currentItems[1] end
        if itemToThrowAway then
            local trashPrompt = _G.AutoDoctor_TrashCache
            if not trashPrompt or not trashPrompt.Parent then
                trashPrompt = nil
                for _, desc in ipairs(workspace:GetDescendants()) do
                    if desc:IsA("ProximityPrompt") then
                        local actText = string.lower(desc.ActionText or "")
                        local objName = string.lower(desc.Parent and desc.Parent.Name or "")
                        if actText:match("trash") or actText:match("throw") or actText:match("dispose") or objName:match("trash") then
                            _G.AutoDoctor_TrashCache = desc; trashPrompt = desc; break
                        end
                    end
                end
            end
            if trashPrompt then
                teleportToTarget(trashPrompt)
                if safeEquip_R7(itemToThrowAway.Name) then
                    local oldReq  = trashPrompt.RequiresLineOfSight
                    local oldDist = trashPrompt.MaxActivationDistance
                    trashPrompt.RequiresLineOfSight   = false
                    trashPrompt.MaxActivationDistance = math.huge
                    trashPrompt.HoldDuration          = 0
                    if type(fireproximityprompt) == "function" then fireproximityprompt(trashPrompt, 1, true)
                    else trashPrompt:InputHoldBegan() task.wait(0.1) trashPrompt:InputHoldEnded() end
                    trashPrompt.RequiresLineOfSight   = oldReq
                    trashPrompt.MaxActivationDistance = oldDist
                    task.wait(0.5)
                end
            end
        end
    end
    local promptToUse = nil
    for _, desc in ipairs(workspace:GetDescendants()) do
        if desc:IsA("ProximityPrompt") then
            local pName = desc.Parent and desc.Parent.Name or ""
            local oText = desc.ObjectText or ""
            local aText = desc.ActionText or ""
            if pName == targetName or oText:match(targetName) or aText:match(targetName) then
                promptToUse = desc; break
            end
        end
    end
    if promptToUse then
        unequipAll()
        teleportToTarget(promptToUse)
        promptToUse.RequiresLineOfSight   = false
        promptToUse.MaxActivationDistance = math.huge
        promptToUse.HoldDuration          = 0
        local gotItem = false
        for retry = 1, 15 do
            if type(fireproximityprompt) == "function" then fireproximityprompt(promptToUse, 1, true)
            else promptToUse:InputHoldBegan() task.wait(0.1) promptToUse:InputHoldEnded() end
            task.wait(0.15)
            if LocalPlayer.Backpack:FindFirstChild(targetName) or
               (LocalPlayer.Character and LocalPlayer.Character:FindFirstChild(targetName)) then
                gotItem = true; break
            end
        end
        _G.AutoRoom7_LastActionTick = tick()
        if gotItem then
            setStatus("Berhasil Mengambil: " .. targetName, "R7")
            InventoryMutex:unlock("R7-fetch")
            return true
        else
            setStatus("GAGAL Mengambil (lag/kosong): " .. targetName, "R7")
            InventoryMutex:unlock("R7-fetch")
            return false
        end
    end
    InventoryMutex:unlock("R7-fetch")
    return false
end

