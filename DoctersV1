local function getActiveEmergencyRoom()
    if autoEnabled_R6 then
        local act6, _, _ = isR6ReallyActive()
        if act6 then
            local npc6, _ = getPatientInEmergency(6, EmergencyCFrames[6].Patient, EmergencyCFrames[6].Radius)
            if not erMemoryCheck(6, npc6) then return 6 end
        end
    end
    if isAutoPlaying_R7 then
        local room7, _ = checkRoom7Status()
        if room7 then return 7 end
    end
    if autoEnabled_R8 then
        local room8 = getEmergencyRoom(8)
        if room8 and not isRoom8HealingDone(room8) then
            local npc8, _ = getPatientInEmergency(8, EmergencyCFrames[8].Bed, EmergencyCFrames[8].Radius)
            if npc8 and not erMemoryCheck(8, npc8) then return 8 end
            local mini8 = room8:FindFirstChild("Minigame")
