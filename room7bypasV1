ToggleAutoBtn.MouseButton1Click:Connect(function()
    isAutoPlaying = not isAutoPlaying
    if isAutoPlaying then
        ToggleAutoBtn.Text = "⏸ AUTO PLAY: ON"
        ToggleAutoBtn.BackgroundColor3 = Color3.fromRGB(70, 200, 70)
        isBusy = false
        _G.AutoRoom7_LastActionTick = tick()
        _G.AutoRoom7_BlacklistTime = 0
        _G.AutoRoom7_IsIdle = false 
        local lastShift = getShiftText()
        startWorker()
        
        if _G.AutoRoom7_Watchdog then task.cancel(_G.AutoRoom7_Watchdog) end
        _G.AutoRoom7_Watchdog = task.spawn(function()
            while isAutoPlaying do
                task.wait(1)
                local currentShift = getShiftText()
                local isShiftChanged = (currentShift ~= lastShift and currentShift ~= nil and lastShift ~= nil)
                
                local idleDuration = tick() - _G.AutoRoom7_LastActionTick
                local isHardStuck = isBusy and (idleDuration > Config.GlobalStuckTimeout)
                local isSoftStuck = isBusy and (idleDuration > Config.StuckTimeout)

                if isShiftChanged or isHardStuck then
                    if isShiftChanged then setStatus("Shift Berganti! Resetting...")
                    else setStatus("SYSTEM HARD-STUCK! Auto Hard-Reset...") end
                    
                    if _G.AutoRoom7_Worker then task.cancel(_G.AutoRoom7_Worker) end
                    isBusy = false
                    _G.AutoRoom7_BlacklistTime = 0
                    _G.AutoRoom7_IsIdle = false 
                    lastShift = currentShift
                    
                    unequipAll()
                    teleportToTarget(Config.IdleCFrame)
                    _G.AutoRoom7_IsIdle = true
                    
                    task.wait(2)
                    if isAutoPlaying then
                        _G.AutoRoom7_LastActionTick = tick()
                        startWorker()
                    end
                elseif isSoftStuck and _G.AutoRoom7_BlacklistTime == 0 then
                    setStatus("Ghost Prompt Detected! Blacklist sementara...")
                    _G.AutoRoom7_BlacklistTime = tick()
                    if _G.AutoRoom7_Worker then task.cancel(_G.AutoRoom7_Worker) end
                    isBusy = false
                    _G.AutoRoom7_IsIdle = false 
                    
                    unequipAll()
                    teleportToTarget(Config.IdleCFrame)
                    _G.AutoRoom7_IsIdle = true
                    
                    task.wait(2)
                    if isAutoPlaying then
                        _G.AutoRoom7_LastActionTick = tick()
                        startWorker()
                    end
                end
                
                if _G.AutoRoom7_BlacklistTime > 0 and (tick() - _G.AutoRoom7_BlacklistTime > Config.BlacklistDuration) then
                    _G.AutoRoom7_BlacklistTime = 0
                    setStatus("[BLACKLIST EXPIRED] Memantau Room 7 kembali...")
                end
                
                if currentShift then lastShift = currentShift end
            end
        end)
    else
        ToggleAutoBtn.Text = "▶ AUTO PLAY: OFF"
        ToggleAutoBtn.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
        if _G.AutoRoom7_Worker then task.cancel(_G.AutoRoom7_Worker) end
        if _G.AutoRoom7_Watchdog then task.cancel(_G.AutoRoom7_Watchdog) end
        _G.AutoRoom7_IsIdle = false 
        setStatus("Dimatikan.")
    end
end)

