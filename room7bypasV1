-- THE ULTIMATE ROOM 7 EXECUTION LOGIC
-- ==========================================
local function executeRoom7(room7, activeShift)
    if isMinigameUIOpen() then
        setStatus("Minigame Berjalan / Memproses Hasil...")
        _G.AutoRoom7_LastActionTick = tick() 
        task.wait(1)
        return
    end

    local minigame = room7:FindFirstChild("Minigame")
    if not minigame then return end
    local bedPart = minigame:FindFirstChild("Bed") and minigame.Bed:FindFirstChild("InBed")
    local currentPatient = findPatientModel(bedPart)

    if not currentPatient then
        setStatus("Pasien telah pergi. Kembali ke Idle...")
        task.wait(1)
        return
    end

    local tv = minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen")
    local healingUI = tv and tv:FindFirstChild("UI") and tv.UI:FindFirstChild("Healing")
    
    -- Jaga-jaga: Kalau logic CheckRoom7Status bocor, tangkap di sini
    if healingUI and healingUI.Visible == true and _G.AutoRoom7_LegitHealing then
        setStatus("Pasien Sembuh / Clear, bersiap ke Idle...")
        task.wait(1) 
        return 
    end

    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if root and (root.Position - Room7_CFrames.Step2.Position).Magnitude > 20 then
        setStatus("Memasuki Ruangan 7...")
        unequipAll()
        teleportToTarget(Room7_CFrames.Step2)
        task.wait(0.5)
    end

    -- 1. CEK LUKA BAKAR ATAU DNA
    if currentPatient then
        for _, desc in ipairs(currentPatient:GetDescendants()) do
            if desc:IsA("ProximityPrompt") and desc.Enabled then
                local actText = string.lower(desc.ActionText or "")
                local name = string.lower(desc.Name or "")
                
                if name == "firepp" or actText:match("burns") then
                    local hasOintment = LocalPlayer.Backpack:FindFirstChild("Ointment") or LocalPlayer.Character:FindFirstChild("Ointment")
                    if not hasOintment then fetchItem("Ointment", {"Ointment"}) end
                    
                    teleportToTarget(desc.Parent)
                    if safeEquip("Ointment") then
                        setStatus("Mengoleskan Ointment (Treat Burns)...")
                        simpleInteract(desc, 3, false)
                        task.wait(1.5) 
                        return
                    end
                elseif actText:match("dna") or name:match("dna") then
                    unequipAll() 
                    setStatus("Mengeklik: Take DNA Sample...")
                    simpleInteract(desc, 0.5, true)
                    task.wait(1.5)
                    return
                end
            end
        end
    end

    -- 2. CEK TV MEDS & ANOMALI
    local reportUI = tv and tv:FindFirstChild("UI") and tv.UI:FindFirstChild("Report")
    local invFolder = reportUI and reportUI:FindFirstChild("inv", true)
    local tvHasMeds = (reportUI and reportUI.Visible and invFolder and #invFolder:GetChildren() > 1)
    
    local inBedPP = nil
    for _, prompt in ipairs(minigame:GetDescendants()) do
        if prompt:IsA("ProximityPrompt") and prompt.Parent and prompt.Parent.Name == "InBed" then
            inBedPP = prompt; break
        end
    end

    if tvHasMeds then
        local pendingMeds = getRoom7PendingMedicines(reportUI)
        
        if #pendingMeds > 0 and checkAnomalyStatus(bedPart) then
            local wrongMedicine = "Medicine"
            for _, item in ipairs(ItemList) do
                if not table.find(pendingMeds, item) then wrongMedicine = item break end
            end
            
            local hasIt = LocalPlayer.Backpack:FindFirstChild(wrongMedicine) or LocalPlayer.Character:FindFirstChild(wrongMedicine)
            if not hasIt then fetchItem(wrongMedicine, {wrongMedicine}) end
            
            teleportToTarget(Room7_CFrames.Step2)
            if safeEquip(wrongMedicine) then
                setStatus("!! MENYUNTIKKAN RACUN (" .. wrongMedicine .. ") !!")
                if inBedPP then simpleInteract(inBedPP, 0.25) end
                task.wait(2)
            end
            return
        end

        if #pendingMeds > 0 then
            for _, obat in ipairs(pendingMeds) do
                local hasIt = LocalPlayer.Backpack:FindFirstChild(obat) or LocalPlayer.Character:FindFirstChild(obat)
                if not hasIt then fetchItem(obat, pendingMeds) end
                
                teleportToTarget(Room7_CFrames.Step2)
                if safeEquip(obat) then 
                    setStatus("Menyuntikkan " .. obat)
                    if inBedPP then simpleInteract(inBedPP, 0.25) end
                    task.wait(Config.InjectionDelay)
                end
            end
        else
            setStatus("Obat Tercentang, Tunggu Healing...")
            if inBedPP then simpleInteract(inBedPP, 0.25) end
            task.wait(1) 
        end
        return 
    end

    -- 3. DYNAMIC ACTION SCANNER (FIXED STRICT BYPASS)
    -- Prioritas 1: Eksekusi normal "collect" jika sudah muncul secara alami (Tidak perlu dibypass)
    for _, prompt in ipairs(minigame:GetDescendants()) do
        if prompt:IsA("ProximityPrompt") and prompt.Enabled then
            local actText = string.lower(prompt.ActionText or "")
            if actText:match("collect") then
                setStatus("Mengambil Hasil: " .. (prompt.ActionText or "Collect"))
                unequipAll()
                simpleInteract(prompt, 0.5, true)
                task.wait(1)
                return
            end
        end
    end

    -- Prioritas 2: Bypass "process" HANYA jika game sedang menyuruh kita melakukan step awal (prepare/set up/begin/turn on)
    local hasEarlyStep = false
    local processPrompt = nil

    for _, prompt in ipairs(minigame:GetDescendants()) do
        if prompt:IsA("ProximityPrompt") then
            local actText = string.lower(prompt.ActionText or "")
            
            if actText:match("process") then
                processPrompt = prompt
            end
            
            if prompt.Enabled and (actText:match("prepare") or actText:match("set up") or actText:match("turn on") or actText:match("begin")) then
                hasEarlyStep = true
            end
        end
    end

    -- Jika ada step awal yang aktif, langsung bypass dan paksa tembak "process"
    if hasEarlyStep and processPrompt then
        setStatus("🔥 BYPASS AKTIF: Menembak " .. (processPrompt.ActionText or "Process"))
        unequipAll()
        
        local oldEnabled = processPrompt.Enabled
        processPrompt.Enabled = true 
        simpleInteract(processPrompt, 0.5, true) 
        processPrompt.Enabled = oldEnabled
        
        task.wait(1)
        return
    -- Jika process muncul secara normal (bukan bypass), eksekusi saja
    elseif processPrompt and processPrompt.Enabled then
        setStatus("Mengeksekusi: " .. (processPrompt.ActionText or "Process"))
        unequipAll()
        simpleInteract(processPrompt, 0.5, true)
        task.wait(1)
        return
    end

    setStatus("Menunggu Reaksi Server / Minigame...")
    task.wait(0.5)
end

