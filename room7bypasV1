local function startWorker()
    if _G.AutoRoom7_Worker then task.cancel(_G.AutoRoom7_Worker) end
    _G.AutoRoom7_Worker = task.spawn(function()
        while isAutoPlaying do
            if not isBusy then
                isBusy = true
                _G.AutoRoom7_LastActionTick = tick()
                
                local activeShift = getShiftText()
                if not activeShift then
                    setStatus("Menunggu shift dimulai...")
                    if not _G.AutoRoom7_IsIdle then
                        unequipAll()
                        teleportToTarget(Config.IdleCFrame)
                        _G.AutoRoom7_IsIdle = true
                    end
                    task.wait(2)
                else
                    local activeRoom, isHealing = checkRoom7Status()
                    
                    if activeRoom then
                        _G.AutoRoom7_IsIdle = false 
                        pcall(function() executeRoom7(activeRoom, activeShift) end)
                        task.wait(0.2)
                    else
                        if _G.AutoRoom7_BlacklistTime > 0 then
                            setStatus("[BLACKLIST] Menunggu Ghost Prompt Expired...")
                        elseif isHealing then
                            setStatus("Pasien Sembuh / Clear")
                        else
                            setStatus("Standby (Menunggu Pasien)...")
                        end
                        
                        if not _G.AutoRoom7_IsIdle then
                            unequipAll()
                            teleportToTarget(Config.IdleCFrame)
                            _G.AutoRoom7_IsIdle = true
                        end
                        
                        task.wait(Config.ScanDelay)
                    end
                end
                isBusy = false
            else
                task.wait(0.5)
            end
        end
    end)
end

