local function hasCriticalPrompts(bedPart)
    local npc = findPatientModel(bedPart)
    if npc then
        for _, desc in ipairs(npc:GetDescendants()) do
            if desc:IsA("ProximityPrompt") and desc.Enabled then
                local actText = string.lower(desc.ActionText or "")
                local name = string.lower(desc.Name or "")
                if name == "firepp" or actText:match("burns") or actText:match("dna") or name:match("dna") then
                    return true
                end
            end
        end
    end
    return false
end

local function hasAnyValidPrompt(room7, bedPart)
    if hasCriticalPrompts(bedPart) then return true end
    
    local minigame = room7:FindFirstChild("Minigame")
    if minigame then
        local validActionTexts = {"prepare", "set up", "turn on", "begin", "process", "collect"}
        for _, prompt in ipairs(minigame:GetDescendants()) do
            if prompt:IsA("ProximityPrompt") and prompt.Enabled then
                local actText = string.lower(prompt.ActionText or "")
                for _, kw in ipairs(validActionTexts) do
                    if actText:match(kw) then return true end
                end
            end
        end
        
        local tv = minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen")
        local reportUI = tv and tv:FindFirstChild("UI") and tv.UI:FindFirstChild("Report")
        if reportUI and reportUI.Visible then
            local pendingMeds = getRoom7PendingMedicines(reportUI)
            if #pendingMeds > 0 then return true end
        end
    end

    return false
end

