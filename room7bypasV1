local function findPatientModel(bedPart)
    if not bedPart then return nil end
    local pos = bedPart.Position
    
    local function checkObj(obj)
        if not obj:IsA("Model") or obj == LocalPlayer.Character then return nil end
        local part = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
        if part and (part.Position - pos).Magnitude <= Config.PatientBedRadius then
            if obj:FindFirstChildOfClass("Humanoid") or obj:FindFirstChildWhichIsA("ProximityPrompt", true) then
                return obj
            end
        end
        return nil
    end
    
    if workspace:FindFirstChild("NPCs") then
        for _, npc in ipairs(workspace.NPCs:GetChildren()) do
            local found = checkObj(npc)
            if found then return found end
        end
    end
    for _, obj in ipairs(workspace:GetChildren()) do
        local found = checkObj(obj)
        if found then return found end
    end
    return nil
end

local function getRoom7PendingMedicines(reportUI)
    local pending = {}
    if not reportUI then return pending end
    local invFolder = reportUI:FindFirstChild("inv", true)
    if not invFolder then return pending end
    
    for _, itemReq in ipairs(invFolder:GetChildren()) do
        if table.find(ItemList, itemReq.Name) then
            local checkMark = itemReq:FindFirstChild("check")
            if not checkMark or (checkMark and checkMark.Visible == false) then table.insert(pending, itemReq.Name) end
        end
    end
    return pending
end

