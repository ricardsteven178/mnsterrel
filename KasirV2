local function updateVisualRadar(id, pos, radius, color, isVisible)
	if not isVisible then
		if _G.SmartCashier_Radars[id] then
			_G.SmartCashier_Radars[id]:Destroy()
			_G.SmartCashier_Radars[id] = nil
		end
		return
	end

	local radar = _G.SmartCashier_Radars[id]
	if not radar or not radar.Parent then
		radar = Instance.new("Part")
		radar.Name = "Radar_" .. id
		radar.Shape = Enum.PartType.Cylinder
		radar.Anchored = true
		radar.CanCollide = false
		radar.CanQuery = false
		radar.CastShadow = false
		radar.Material = Enum.Material.Neon
		radar.Transparency = 0.85
		radar.Color = color
		radar.Parent = workspace
		_G.SmartCashier_Radars[id] = radar
	end

	radar.Size = Vector3.new(0.1, radius * 2, radius * 2)
	radar.CFrame = CFrame.new(pos.X, pos.Y - 1.45, pos.Z) * CFrame.Angles(0, 0, math.rad(90))
end

local function getPromptPosition(prompt)
	local currentParent = prompt.Parent
	while currentParent do
		if currentParent:IsA("BasePart") or currentParent:IsA("Model") or currentParent:IsA("Tool") then
			local success, pos = pcall(function() return currentParent:GetPivot().Position end)
			if success and pos then return pos end
		end
		currentParent = currentParent.Parent
	end
	return nil
end

-- [NEW] Cek apakah ada prompt aktif (Enabled) di dalam radius Radar3
-- Ini AMAN dibaca dari jauh karena .Enabled adalah server-side property
-- Tidak pakai .Visible karena itu client-side render state, misleading kalau player jauh
local function hasActivePromptInRadar3()
	for _, desc in ipairs(workspace:GetDescendants()) do
		if desc:IsA("ProximityPrompt") and desc.Enabled then
			local pos = getPromptPosition(desc)
			if pos then
				local dist = (pos - Config.CenterPointRadar3.Position).Magnitude
				if dist <= Config.RadarRadius3 then
					return true
				end
			end
		end
	end
	return false
end

-- [NEW] Teleport cerdas: hanya teleport paksa kalau ada prompt aktif di Radar3
-- Kalau tidak ada prompt aktif, player dibiarkan diam — tidak dipaksa pindah
local function smartTeleportToCashier(reason)
	if not Config.TeleportSebelumMelayani then return end

	local char = LocalPlayer.Character
	local root = char and char:FindFirstChild("HumanoidRootPart")
	if not root then return end

	local distFromCashier = (root.Position - Config.CashierCFrame.Position).Magnitude

	-- Sudah dekat, tidak perlu teleport
	if distFromCashier <= Config.ForceTeleportThreshold then return end

	-- [KUNCI UTAMA]: Cek dulu apakah ada pekerjaan aktif di zona Radar3
	-- Kalau tidak ada prompt sama sekali di zona itu, jangan paksa teleport
	local promptExists = hasActivePromptInRadar3()

	if promptExists then
		logInfo("-> Teleport paksa ke kasir [" .. reason .. "] — ada prompt aktif di Radar3")
		root.CFrame = Config.CashierCFrame
		root.Velocity = Vector3.new(0, 0, 0)
		task.wait(0.2)
	else
		-- Tidak ada yang perlu dikerjakan, biarkan player di tempat
		logInfo("-> Tidak ada prompt di Radar3, skip teleport [" .. reason .. "]")
	end
end

-- Teleport ke lokasi spesifik (shutter, item, dll) — tetap pakai distance check biasa
local function teleportTo(targetCFrame, namaLokasi)
	if not Config.TeleportSebelumMelayani then return end
	local char = LocalPlayer.Character
	local root = char and char:FindFirstChild("HumanoidRootPart")
	if root then
		local distance = (root.Position - targetCFrame.Position).Magnitude
		if distance > 3 then
			logInfo("Teleport -> " .. namaLokasi)
			root.CFrame = targetCFrame
			root.Velocity = Vector3.new(0, 0, 0)
			task.wait(0.2)
		end
	end
end

-- Teleport ke posisi prompt (untuk item pickup, event, dll)
-- Dengan fallback: kalau getPromptPosition nil, skip — jangan silent fail
local function teleportToPrompt(prompt)
	if not Config.TeleportSebelumMelayani then return false end
	local pos = getPromptPosition(prompt)
	if not pos then
		logInfo("⚠️ teleportToPrompt: posisi prompt tidak ditemukan, skip teleport")
		return false
	end
	local char = LocalPlayer.Character
	local root = char and char:FindFirstChild("HumanoidRootPart")
	if root then
		local dist = (root.Position - pos).Magnitude
		if dist > 3 then
			root.CFrame = CFrame.new(pos + Vector3.new(0, 3.5, 0))
			root.Velocity = Vector3.new(0, 0, 0)
			task.wait(0.25)
		end
	end
	return true
end

local function firePrompt(prompt)
	if prompt and prompt:IsA("ProximityPrompt") then
		local oldReq = prompt.RequiresLineOfSight
		local oldDist = prompt.MaxActivationDistance
		local oldHold = prompt.HoldDuration

		prompt.RequiresLineOfSight = false
		prompt.MaxActivationDistance = math.huge
		prompt.HoldDuration = 0

		if type(fireproximityprompt) == "function" then
			fireproximityprompt(prompt, 1, true)
		else
			prompt:InputHoldBegan()
			task.wait(0.05)
			prompt:InputHoldEnded()
		end

		prompt.RequiresLineOfSight = oldReq
		prompt.MaxActivationDistance = oldDist
		prompt.HoldDuration = oldHold

		return true
	end
	return false
end

local function isReady(prompt)
	if not prompt or not prompt.Enabled then return false end
	if actionCooldowns[prompt] and tick() < actionCooldowns[prompt] then return false end
	return true
end

local function autoClickScreen()
	pcall(function()
		if type(mouse1click) == "function" then
			mouse1click()
		else
			local vim = game:GetService("VirtualInputManager")
			vim:SendMouseButtonEvent(500, 500, 0, true, game, 1)
			task.wait(0.05)
			vim:SendMouseButtonEvent(500, 500, 0, false, game, 1)
		end
	end)
end

