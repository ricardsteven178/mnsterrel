if Config.AutoStartEnabled then
	autoCashierEnabled = true
	ToggleBtn.Text = "TRUE AI: ON"
	ToggleBtn.BackgroundColor3 = Color3.fromRGB(70, 200, 70)
	logInfo("AUTO START: Kasir langsung aktif.")
end

if Config.StartMinimized then
	setMinimize(true)
end

ToggleBtn.MouseButton1Click:Connect(function()
