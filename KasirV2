							local coffeePP = getPromptByActionExact("coffee")
							if coffeePP then
								logInfo("☕ Mencari Kopi untuk Barney...")
								teleportToPrompt(coffeePP)
								firePrompt(coffeePP)
								actionCooldowns[coffeePP] = tick() + 2.5
							end
							return
						else
							equipItem("coffee")
						end
					elseif specialType == "give scalpel" then
						if not hasItem("scalpel") then
							local scalpelPP = getPromptByActionExact("scalpel")
							if scalpelPP then
								logInfo("🔪 Mencari Scalpel...")
								teleportToPrompt(scalpelPP)
								firePrompt(scalpelPP)
								actionCooldowns[scalpelPP] = tick() + 2.5
							end
							return
						else
							equipItem("scalpel")
						end
					end

					logInfo("🌟 EVENT INSTAN: " .. specialType)
					teleportToPrompt(specialPrompt)
					firePrompt(specialPrompt)
					actionCooldowns[specialPrompt] = tick() + 2.5
					return
				end

				-- =======================================
				-- [STALKER OVERRIDE]
				-- =======================================
				if isStalkerActive then
					logInfo("⚠️ MENUNGGU STALKER! Standby di kasir.")
					teleportTo(Config.CashierCFrame, "Meja Kasir (Standby Stalker)")
					return
				end

				-- =======================================
				-- [PRIORITAS 1] RUTINITAS KASIR
				-- =======================================
				local shutterPP = workspace:FindFirstChild("Misc") and workspace.Misc:FindFirstChild("ShutterButton") and workspace.Misc.ShutterButton:FindFirstChild("PP")

				if #normalNPCs > 0 then
					if shutterPP and shutterPP.ActionText == "Open" then
						teleportTo(Config.ShutterCFrame, "Tombol Shutter")
						firePrompt(shutterPP)
						-- [NEW] Setelah buka shutter, cek dulu ada prompt gak sebelum balik kasir
						smartTeleportToCashier("Setelah Buka Shutter")
						return
					end

					local targetNPC = normalNPCs[1]
					local myCounter = getClosestCounter(targetNPC)
					local deskPrompt, stepName = getActiveDeskPrompt(myCounter)

					if deskPrompt then
						actionCooldowns[deskPrompt] = tick() + 2.5
						logInfo("-> [" .. (myCounter and myCounter.Name or "Unknown") .. "] Eksekusi: " .. stepName)
						-- [NEW] Teleport paksa ke kasir hanya kalau ada prompt aktif di Radar3
						smartTeleportToCashier("Sebelum Eksekusi " .. stepName)
						firePrompt(deskPrompt)
					else
						local talkPrompt = nil
						for _, desc in ipairs(targetNPC:GetDescendants()) do
							if desc:IsA("ProximityPrompt") and desc.Enabled and string.match(string.lower(desc.ActionText), "talk") then
								if isReady(desc) then talkPrompt = desc break end
							end
						end

						if talkPrompt then
							actionCooldowns[talkPrompt] = tick() + 2.5
							logInfo("-> Selesai melayani (Talk): " .. targetNPC.Name)
							smartTeleportToCashier("Sebelum Talk")
							task.wait(0.2)
							firePrompt(talkPrompt)
						else
							-- [FIX DEAD ZONE]: Hanya recovery kalau memang ada prompt di Radar3
							-- Ini eliminasi dead zone 4-8 stud yang bikin player stuck sebelumnya
							local char = LocalPlayer.Character
							local root = char and char:FindFirstChild("HumanoidRootPart")
							if root then
								local dist = (root.Position - Config.CashierCFrame.Position).Magnitude
								if dist > Config.RecoveryThreshold and hasActivePromptInRadar3() then
									logInfo("-> Recovery: prompt ada di Radar3, kalibrasi posisi kasir...")
									teleportTo(Config.CashierCFrame, "Meja Kasir (Recovery)")
								else
									logInfo("-> Tidak ada prompt di Radar3, idle — tidak recovery paksa")
								end
							end
						end
					end
					return
				end

				if #anomalyNPCs > 0 then
					if shutterPP and shutterPP.ActionText == "Close" then
						logInfo("-> ANOMALI! Menutup Pintu...")
						teleportTo(Config.ShutterCFrame, "Tombol Shutter")
						firePrompt(shutterPP)
						-- [NEW] Balik ke kasir hanya kalau ada prompt aktif
						smartTeleportToCashier("Setelah Tutup Shutter (Anomali)")
					else
						local char = LocalPlayer.Character
						local root = char and char:FindFirstChild("HumanoidRootPart")
						if root then
							local dist = (root.Position - Config.CashierCFrame.Position).Magnitude
							-- [FIX] Dead zone dihilangkan: recovery hanya kalau ada prompt
							if dist > Config.RecoveryThreshold and hasActivePromptInRadar3() then
								teleportTo(Config.CashierCFrame, "Meja Kasir (Anomali Recovery)")
							end
						end
					end
					return
				end

				-- Meja kosong, cek shutter
				local checkIn1 = workspace:FindFirstChild("Misc") and workspace.Misc:FindFirstChild("CheckIn")
				local checkIn2 = workspace:FindFirstChild("Misc") and workspace.Misc:FindFirstChild("CheckIn2")
				local form1 = checkIn1 and checkIn1:FindFirstChild("Form")
				local form2 = checkIn2 and checkIn2:FindFirstChild("Form")

				if not form1 and not form2 and #normalNPCs == 0 and #anomalyNPCs == 0 then
					if shutterPP and shutterPP.ActionText == "Open" then
						logInfo("-> Meja bersih. Membuka gerbang...")
						teleportTo(Config.ShutterCFrame, "Tombol Shutter")
						firePrompt(shutterPP)
						-- [NEW] Idle state: tidak balik kasir paksa kalau tidak ada prompt
						smartTeleportToCashier("Setelah Buka (Idle)")
					end
				end

			end)

			if not success then
				logInfo("⚠️ SYSTEM ERROR: " .. tostring(err))
			end
		end
	end
end)

