		ToggleBtn.Text = "TRUE AI: ON"
		ToggleBtn.BackgroundColor3 = Color3.fromRGB(70, 200, 70)
		logInfo("SISTEM DINYALAKAN")
	else
		ToggleBtn.Text = "TRUE AI: OFF"
		ToggleBtn.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
		logInfo("SISTEM DIMATIKAN")
	end
end)

RadarBtn.MouseButton1Click:Connect(function()
	isRadarVisible = not isRadarVisible
	RadarBtn.Text = isRadarVisible and "SHOW RADAR: ON" or "SHOW RADAR: OFF"
	RadarBtn.BackgroundColor3 = isRadarVisible and Color3.fromRGB(70, 200, 70) or Color3.fromRGB(70, 70, 70)
end)

CloseBtn.MouseButton1Click:Connect(function()
	autoCashierEnabled = false
	isRadarVisible = false
	if _G.SmartCashier_Main then _G.SmartCashier_Main:Destroy() end
	if _G.SmartCashier_Radars then
		for _, radar in pairs(_G.SmartCashier_Radars) do
			if radar then radar:Destroy() end
		end
	end
	_G.SmartCashier_ExecutionID = nil
end)
