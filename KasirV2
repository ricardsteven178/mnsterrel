				end
			end

			StatusR1.Text = "R1 (CheckIn 1): " .. r1_status
			StatusR2.Text = "R2 (CheckIn 2): " .. r2_status
			StatusR4.Text = "R4 (Ask to Leave): " .. r4_status
		end)

		if autoCashierEnabled then
			local success, err = pcall(function()

				-- =======================================
				-- [PRIORITAS 0] EVENT & STALKER
				-- =======================================
				local specialPrompt, specialType = getSpecialPrompt(isStalkerActive)

				if specialPrompt then
