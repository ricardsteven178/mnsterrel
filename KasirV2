-- ANOMALY DETECTION
-- ==========================================
local function isAnomaly(npc)
	local lowerName = string.lower(npc.Name or "Unknown")
	if lowerName == "doctor" then return false end
	if string.find(lowerName, "monster") or string.find(lowerName, "ghost") then return true end
	local attr = npc:GetAttributes()
	if attr.Skinwalker or attr.SkinwalkerEasy or attr.PenaltyWhenLettingIn or attr.PhotoEffect == "CursedPhoto" or attr.PhotoEffect2 == "CursedPhoto" then
		return true
	end
	return false
end

local function getClosestCounter(npc)
	local checkIn1 = workspace:FindFirstChild("Misc") and workspace.Misc:FindFirstChild("CheckIn")
	local checkIn2 = workspace:FindFirstChild("Misc") and workspace.Misc:FindFirstChild("CheckIn2")
	local npcPos = npc:GetPivot().Position
	local d1 = (npcPos - Config.CenterPointRadar1.Position).Magnitude
	local d2 = (npcPos - Config.CenterPointRadar2.Position).Magnitude
	if d2 < d1 and checkIn2 then return checkIn2 else return checkIn1 end
end

local function hasItem(itemName)
	local char = LocalPlayer.Character
	local bp = LocalPlayer:FindFirstChild("Backpack")
	local function checkFolder(folder)
		if not folder then return false end
		for _, v in ipairs(folder:GetChildren()) do
			if v:IsA("Tool") and string.match(string.lower(v.Name), string.lower(itemName)) then
				return true
			end
		end
		return false
	end
	return checkFolder(char) or checkFolder(bp)
end

local function equipItem(itemName)
	local char = LocalPlayer.Character
	local hum = char and char:FindFirstChild("Humanoid")
	local bp = LocalPlayer:FindFirstChild("Backpack")
	if not hum or not bp then return end
	for _, v in ipairs(bp:GetChildren()) do
		if v:IsA("Tool") and string.match(string.lower(v.Name), string.lower(itemName)) then
			hum:EquipTool(v)
			task.wait(0.2)
			return
		end
	end
end

local function getPromptByActionExact(actionName)
	for _, desc in ipairs(workspace:GetDescendants()) do
		if desc:IsA("ProximityPrompt") and desc.Enabled then
			local act = string.lower(desc.ActionText or "")
			if act == actionName then
				if isReady(desc) then return desc end
			end
		end
	end
	return nil
end

-- ==========================================
-- SPECIAL EVENT DETECTION
-- ==========================================
local specialActions = {
	"give coffee",
	"accept suitcase",
	"give scalpel",
	"let him hide with you",
	"accept gift",
	"ask to leave",
	"accept helping her"
}

local function getSpecialPrompt(isStalkerActive)
	for _, desc in ipairs(workspace:GetDescendants()) do
		if desc:IsA("ProximityPrompt") and desc.Enabled then
			local actText = string.lower(desc.ActionText or "")
			for _, special in ipairs(specialActions) do
				if string.match(actText, special) then
					if isReady(desc) then return desc, special end
				end
			end
			if isStalkerActive and actText == "inspect" then
				if isReady(desc) then return desc, "inspect (stalker)" end
			end
			if string.lower(desc.Name) == "stalkerpp" and actText == "take photo" then
				if isReady(desc) then return desc, "take photo (stalker)" end
			end
		end
	end
	return nil, nil
end

-- ==========================================
-- DESK PROMPT DETECTION
-- ==========================================
local function getActiveDeskPrompt(counter)
	if not counter then return nil, nil end
	local checkIn1 = workspace:FindFirstChild("Misc") and workspace.Misc:FindFirstChild("CheckIn")

	local formPP = counter:FindFirstChild("Form") and counter.Form:FindFirstChild("PP")
	if isReady(formPP) then return formPP, "Stamp Form" end

	for _, desc in ipairs(workspace:GetDescendants()) do
		if desc:IsA("ProximityPrompt") and desc.Enabled then
			local txt = string.lower(desc.ActionText or "")
			if txt == "take photo" and string.lower(desc.Name) ~= "stalkerpp" then
				if isReady(desc) then return desc, "Take Photo" end
			end
		end
	end

	local compPP = checkIn1 and checkIn1:FindFirstChild("Computer") and checkIn1.Computer:FindFirstChild("PP")
	if isReady(compPP) then return compPP, "Register" end

	local printPP = checkIn1 and checkIn1:FindFirstChild("Printer") and checkIn1.Printer:FindFirstChild("PP")
	if isReady(printPP) then return printPP, "Print Badge" end

	for _, desc in ipairs(workspace:GetDescendants()) do
		if desc:IsA("ProximityPrompt") and desc.Enabled then
			local txt = string.lower(desc.ActionText)
			if string.match(txt, "take") and not string.match(txt, "photo") then
				local pos = getPromptPosition(desc)
				if pos and (pos - Config.CenterPointRadar3.Position).Magnitude <= Config.RadarRadius3 then
					if isReady(desc) then return desc, "Take Item" end
				end
				-- [FIX] Kalau pos nil, skip — jangan fallback ke prompt random
			end
		end
	end

	return nil, nil
end

