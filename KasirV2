local function setMinimize(state)
	isMinimized = state
	ContentFrame.Visible = not state
	MainFrame.Size = state and UDim2.new(0, 250, 0, 30) or UDim2.new(0, 250, 0, 220)
	MinimizeBtn.Text = state and "▢" or "—"
end

MinimizeBtn.MouseButton1Click:Connect(function()
	setMinimize(not isMinimized)
end)

