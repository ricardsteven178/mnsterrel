local Lib = require(RS:WaitForChild("Lib"))

-- ============================================
-- STATE (edit disini)
-- ============================================
local enabled = true   -- true = auto ON, false = auto OFF
local minimized = false  -- true = auto minimize, false = expanded
local connections = {}

-- ============================================
-- CORE LOGIC
-- ============================================
local oldPlayCutscene = Lib.Import("PlayCutscene")
local oldControls = Lib.Import("PlayerControlsEnabled")
local oldGameOver = Lib.Import("ShowGameOverScreen")

local function enableBlock()
    -- Strikes watcher
    local strikesFrame = LP.PlayerGui:WaitForChild("Strikes"):WaitForChild("Frame")
    strikesFrame.Visible = false
    local strikeConn = strikesFrame:GetPropertyChangedSignal("Visible"):Connect(function()
        if enabled and strikesFrame.Visible then
            strikesFrame.Visible = false
            print("[NGE] Strikes re-hidden")
        end
    end)
    table.insert(connections, strikeConn)

    Lib.Inject("PlayCutscene", function(cutsceneName, ...)
        if not enabled then
            return oldPlayCutscene and oldPlayCutscene(cutsceneName, ...) or nil
        end
        if cutsceneName == "ThreePatientsDiedEnding" then
            print("[NGE] Blocked cutscene: ThreePatientsDiedEnding")
            return
        end
        return oldPlayCutscene and oldPlayCutscene(cutsceneName, ...) or nil
    end)

    Lib.Inject("ShowGameOverScreen", function(...)
        if not enabled then
            return oldGameOver and oldGameOver(...) or nil
        end
        print("[NGE] Blocked GameOverScreen")
    end)

    Lib.Inject("PlayerControlsEnabled", function(val, ...)
        if not enabled then
            return oldControls and oldControls(val, ...) or nil
        end
        if val == false then
            print("[NGE] Blocked PlayerControlsEnabled(false)")
            return
        end
        return oldControls and oldControls(val, ...) or nil
    end)

    local tagConn = CS:GetInstanceAddedSignal("GameOver"):Connect(function(inst)
        if not enabled then return end
        print("[NGE] GameOver tag removed")
        CS:RemoveTag(inst, "GameOver")
        pcall(function() Lib.HideDeathScreen() end)
        pcall(function() Lib.PlayerControlsEnabled(true) end)
    end)
    table.insert(connections, tagConn)

    local Net = RS:WaitForChild("Util"):WaitForChild("Net")
    for _, v in ipairs(Net:GetDescendants()) do
        if v:IsA("RemoteEvent") then
            if v.Name == "RE/TeleportToLobby" or v.Name == "RE/PlayCutscene" then
                local c = v.OnClientEvent:Connect(function(arg1, ...)
                    if not enabled then return end
                    if v.Name == "RE/PlayCutscene" and arg1 == "ThreePatientsDiedEnding" then
                        print("[NGE] Network blocked: ThreePatientsDiedEnding")
                        return
                    end
                    if v.Name == "RE/TeleportToLobby" then
                        print("[NGE] TeleportToLobby blocked")
                        return
                    end
                end)
                table.insert(connections, c)
            end
        end
    end

    local function guardBlur(blur)
        local c = blur:GetPropertyChangedSignal("Size"):Connect(function()
            if enabled and blur.Size > 0 then
                blur.Size = 0
                print("[NGE] Blur suppressed")
            end
        end)
        table.insert(connections, c)
    end

    local existing = Lighting:FindFirstChildOfClass("BlurEffect")
    if existing then guardBlur(existing) end

    local addConn = Lighting.ChildAdded:Connect(function(child)
        if child:IsA("BlurEffect") then guardBlur(child) end
    end)
    table.insert(connections, addConn)

    local blur = Lighting:FindFirstChildOfClass("BlurEffect")
    if blur then blur.Size = 0 end
end

local function disableBlock()
    for _, c in ipairs(connections) do
        pcall(function() c:Disconnect() end)
    end
    connections = {}

    -- Restore Strikes
    pcall(function()
        LP.PlayerGui:WaitForChild("Strikes"):WaitForChild("Frame").Visible = true
    end)

    if oldPlayCutscene then Lib.Inject("PlayCutscene", oldPlayCutscene) end
    if oldGameOver then Lib.Inject("ShowGameOverScreen", oldGameOver) end
    if oldControls then Lib.Inject("PlayerControlsEnabled", oldControls) end
    print("[NGE] Disabled")
end

