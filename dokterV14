local function getPlacePatientPrompt()
    local roomsFolder = workspace:FindFirstChild("Rooms")
    if not roomsFolder then return nil, nil, nil, nil end
    
    local medicalFolder = roomsFolder:FindFirstChild("Medical")
    if medicalFolder then
        for i = 1, Config.MaxRooms do
            local room = medicalFolder:FindFirstChild("Room" .. i)
            if room then
                for _, desc in ipairs(room:GetDescendants()) do
                    if desc:IsA("ProximityPrompt") and desc.Enabled then
                        local actText = string.lower(desc.ActionText or "")
                        if actText:match("place") then return desc, room.Name, i, room end
                    end
                end
            end
        end
    end

    local emergencyFolder = roomsFolder:FindFirstChild("Emergency")
    if emergencyFolder and Config.EmergencyRooms then
        for _, i in ipairs(Config.EmergencyRooms) do
            local room = emergencyFolder:FindFirstChild("Room" .. i)
            if room then
                for _, desc in ipairs(room:GetDescendants()) do
                    if desc:IsA("ProximityPrompt") and desc.Enabled then
                        local actText = string.lower(desc.ActionText or "")
                        if actText:match("place") then return desc, room.Name, tonumber(i), room end
                    end
                end
            end
        end
    end
    
    return nil, nil, nil, nil
end

local function getPatientInRoom(roomNum, roomPath)
    local bedPart = roomPath and roomPath:FindFirstChild("Minigame") and roomPath.Minigame:FindFirstChild("Bed") and roomPath.Minigame.Bed:FindFirstChild("InBed")
    
    local centerPos = bedPart and bedPart.Position
    if not centerPos and RoomCFrames[roomNum] then centerPos = RoomCFrames[roomNum].Position end
    if not centerPos and roomPath and roomPath.PrimaryPart then centerPos = roomPath.PrimaryPart.Position end
    
    if not centerPos then return nil end
    
    local radius = Config.PatientBedRadius

    local function checkNPC(obj)
        if Players:GetPlayerFromCharacter(obj) then return nil end
        local part = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
        if part and (part.Position - centerPos).Magnitude <= radius then
            local isRealPatient = false
            for _, pp in ipairs(obj:GetDescendants()) do
                if pp:IsA("ProximityPrompt") then
                    local txt = string.lower(pp.ActionText or "")
                    if txt:match("dna") or txt:match("treat") or pp.Name == "FirePP" then
                        isRealPatient = true
                        break
                    end
                end
            end
            if isRealPatient then return obj end
        end
        return nil
    end

    if workspace:FindFirstChild("NPCs") then
        for _, npc in ipairs(workspace.NPCs:GetChildren()) do
            local found = checkNPC(npc)
            if found then return found end
        end
    end
    
    for _, obj in ipairs(workspace:GetChildren()) do
        if obj:IsA("Model") and obj ~= LocalPlayer.Character and obj.Name ~= "Rooms" and obj.Name ~= "Misc" then
            local found = checkNPC(obj)
            if found then return found end
        end
    end
    return nil
end

local function getFireEmergency()
    if workspace:FindFirstChild("NPCs") then
        for _, npc in ipairs(workspace.NPCs:GetChildren()) do
            local pp = npc:FindFirstChild("FirePP", true)
            if pp and pp.ActionText and pp.ActionText:match("Fire") then return npc, pp end
        end
    end
    for _, obj in ipairs(workspace:GetChildren()) do
        if obj:IsA("Model") and obj:FindFirstChild("Humanoid") then
            local pp = obj:FindFirstChild("FirePP", true)
            if pp and pp.ActionText and pp.ActionText:match("Fire") then return obj, pp end
        end
    end
    return nil, nil
end

local function findActiveRoom()
    local roomsFolder = workspace:FindFirstChild("Rooms")
    local medicalFolder = roomsFolder and roomsFolder:FindFirstChild("Medical")
    if not medicalFolder then return nil, nil end

    for i = 1, Config.MaxRooms do
        local room = medicalFolder:FindFirstChild("Room" .. i)
        if room then
            local isBlacklisted = BuggedRoomBlacklist[i] and (tick() - BuggedRoomBlacklist[i] < Config.BlacklistDuration)
            if not isBlacklisted then
                local minigame = room:FindFirstChild("Minigame")
                local bed = minigame and minigame:FindFirstChild("Bed") and minigame.Bed:FindFirstChild("InBed")
                
                local ready, reason = isPatientReady(room, bed)
                local isHealing = isHealingDone(minigame, room, bed)
                
                if ready and not isHealing then
                    _G.AutoDoctor_RoomMemory[i] = nil 
                    if Config.ShowConsoleLogs then print("[RADAR] ➔ Target Dikunci: " .. room.Name .. " (" .. reason .. ")") end
                    return room, i 
                end
                
                local signLight = room:FindFirstChild("MainSign") and room.MainSign:FindFirstChild("Light")
                local isLightRed = signLight and (signLight.BrickColor.Name == "Crimson" or signLight.Color == Color3.fromRGB(165, 0, 0))
                
                if not isLightRed and _G.AutoDoctor_RoomMemory[i] == "PatientLeaving" then
                    _G.AutoDoctor_RoomMemory[i] = nil
                end
            end
        end
    end

    return nil, nil 
end

local function getFaintedPatient()
    if workspace:FindFirstChild("NPCs") then
        for _, npc in ipairs(workspace.NPCs:GetChildren()) do
            local pp = npc:FindFirstChild("FaintedPP", true) or npc:FindFirstChildWhichIsA("ProximityPrompt", true)
            if pp and (pp.Name == "FaintedPP" or (pp.ActionText and pp.ActionText:match("Carry"))) then return npc, pp end
        end
    end
    for _, obj in ipairs(workspace:GetChildren()) do
        if obj:IsA("Model") then
            local pp = obj:FindFirstChild("FaintedPP", true) or obj:FindFirstChildWhichIsA("ProximityPrompt", true)
            if pp and (pp.Name == "FaintedPP" or (pp.ActionText and pp.ActionText:match("Carry"))) then return obj, pp end
        end
    end
    return nil, nil
end

local function processFaintedPatient(faintedPart, carryPP, activeShift)
    setStatus("! PRIORITAS 2: Mengurus Pasien Pingsan !")
    unequipAll()
    teleportToTarget(faintedPart.PrimaryPart or faintedPart:FindFirstChildWhichIsA("BasePart"))
    
    setStatus("Menggendong pasien...")
    simpleInteract(carryPP, 0, true)
    task.wait(1.5)

    local placePrompt, targetRoomName, targetRoomNum, targetRoomPath = nil, nil, nil, nil
    local waitLimit = 0
    
    while not placePrompt and waitLimit < 20 do
        if getShiftText() ~= activeShift then return end
        setStatus("Mencari kasur kosong...")
        
        placePrompt, targetRoomName, targetRoomNum, targetRoomPath = getPlacePatientPrompt()
        
        if not placePrompt then
            task.wait(1.5)
            waitLimit = waitLimit + 1
            _G.AutoDoctor_LastActionTick = tick()
        end
        task.wait(0.1) 
    end

    if placePrompt and targetRoomNum and targetRoomPath then
        setStatus("Membawa ke " .. targetRoomName .. "...")
        unequipAll()
        teleportToRoomCenter(targetRoomNum, targetRoomPath) 
        task.wait(0.3)
        
        setStatus("Meletakkan di kasur...")
        simpleInteract(placePrompt, 1, true)
        task.wait(1.5)
        
        setStatus("Berhasil menaruh pasien! Kembali bekerja...")
    else
        setStatus("GAGAL menaruh pasien. Kasur penuh / shift ganti.")
    end
end

-- ==========================================
-- THE ULTIMATE TREATMENT ENGINE
-- ==========================================
local function executeTreatmentCore(roomPath, roomNum, activeShift)
    local minigame = roomPath:FindFirstChild("Minigame")
    if not minigame then return end
    
    local bed = minigame:FindFirstChild("Bed") and minigame.Bed:FindFirstChild("InBed")

    setStatus("--- MEMULAI PENGOBATAN: " .. roomPath.Name .. " ---")
    teleportToRoomCenter(roomNum, roomPath) 

    local lastProgressTime = tick()
    local justProcessedTick = 0 

    while true do
        task.wait(0.1) 

        if getShiftText() ~= activeShift then 
            setStatus("Shift berganti! Membatalkan pengobatan.")
            break 
        end
        
        if getFireEmergency() or getPlacePatientPrompt() then
            setStatus("INTERUPSI DARURAT! Menunda...")
            break
        end

        local currentPatient = getPatientInRoom(roomNum, roomPath)
        if not currentPatient then
            local signLight = roomPath:FindFirstChild("MainSign") and roomPath.MainSign:FindFirstChild("Light")
            local isLightRed = signLight and (signLight.BrickColor.Name == "Crimson" or signLight.Color == Color3.fromRGB(165, 0, 0))

            if isLightRed then
                setStatus("Pasien sedang berjalan ke kasur... Menunggu.")
                task.wait(1)
            else
                setStatus("Kamar kosong / Ghost Prompt! Skip.")
                BuggedRoomBlacklist[roomNum] = tick() 
                break
            end
        end

        if isHealingDone(minigame, roomPath, bed) then
            if tick() - justProcessedTick < 5 then
                setStatus("Menunggu sinkronisasi TV (Loading Resep)...")
                task.wait(1)
            else
                setStatus("Pasien Sembuh! Menyimpan ke memori: Pasien sedang keluar...")
                _G.AutoDoctor_RoomMemory[roomNum] = "PatientLeaving"
                break
            end
        end

        if tick() - lastProgressTime >= Config.StuckTimeout then
            setStatus("Timeout! Skip ruangan.")
            BuggedRoomBlacklist[roomNum] = tick()
            break
        end

        local tvUI = minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen", true)
        local pendingMeds = getPendingMedicines(tvUI)
        local hasTasks, reason = isPatientReady(roomPath, bed)

        if hasTasks then
            if reason == "TV Aktif (Butuh Obat)" then
                local patientIsAnomaly = checkAnomalyStatus(bed)
                
                if patientIsAnomaly then
                    local prescribedMeds = {}
                    local tvInv = tvUI:FindFirstChild("inv", true)
                    if tvInv then
                        for _, req in ipairs(tvInv:GetChildren()) do
                            if table.find(ItemList, req.Name) then table.insert(prescribedMeds, req.Name) end
                        end
                    end
                    
                    local wrongMedicine = nil
                    for _, item in ipairs(ItemList) do
                        if not table.find(prescribedMeds, item) then
                            local p = getPromptFromCache(item, false)
                            if p then
                                wrongMedicine = item
                                break
                            end
                        end
                    end
                    if not wrongMedicine then wrongMedicine = "Medicine" end
                    
                    local hasIt = LocalPlayer.Backpack:FindFirstChild(wrongMedicine) or LocalPlayer.Character:FindFirstChild(wrongMedicine)
                    if not hasIt then fetchItem(wrongMedicine, {wrongMedicine}) end
                    
                    if bed and bed:FindFirstChild("PP") then
                        teleportToTarget(bed:FindFirstChild("PP").Parent)
                        if turboSafeEquip(wrongMedicine) then
                            local activeTool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
                            if activeTool and activeTool.Name == wrongMedicine then
                                setStatus("MENYUNTIKKAN RACUN: " .. wrongMedicine)
                                simpleInteract(bed.PP, 0.1, false)
                                lastProgressTime = tick() 
                                task.wait(2) 
                                
                                setStatus("--- ANOMALI HANGUS! Menyimpan ke memori... ---")
                                _G.AutoDoctor_RoomMemory[roomNum] = "PatientLeaving"
                                break 
                            end
                        else
                            setStatus("FAILSAFE: Gagal pegang racun. Server Lag.")
                        end
                    end
                else
                    local currentPending = getPendingMedicines(tvUI)
                    for _, obat in ipairs(currentPending) do
                        local hasIt = LocalPlayer.Backpack:FindFirstChild(obat) or LocalPlayer.Character:FindFirstChild(obat)
                        if not hasIt then
                            local totalCount, currentItems = checkTotalInventory()
                            local hasTrash = false
                            for _, item in ipairs(currentItems) do
                                if not table.find(currentPending, item.Name) then
                                    hasTrash = true
                                    break
                                end
                            end
                            
                            if totalCount < Config.MaxInventory or hasTrash then
                                fetchItem(obat, currentPending)
                                task.wait(0.1)
                            end
                        end
                    end

                    local medsWeHaveAndNeed = {}
                    currentPending = getPendingMedicines(tvUI)
                    for _, obat in ipairs(currentPending) do
                        if LocalPlayer.Backpack:FindFirstChild(obat) or LocalPlayer.Character:FindFirstChild(obat) then
                            table.insert(medsWeHaveAndNeed, obat)
                        end
                    end

                    if #medsWeHaveAndNeed > 0 then
                        local obatToInject = medsWeHaveAndNeed[1]
                        if bed and bed:FindFirstChild("PP") then
                            teleportToTarget(bed:FindFirstChild("PP").Parent)
                            if turboSafeEquip(obatToInject) then
                                local activeTool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
                                if activeTool and activeTool.Name == obatToInject then
                                    setStatus("Suntik: " .. obatToInject)
                                    simpleInteract(bed.PP, 0.1, false)
                                    lastProgressTime = tick()
                                    task.wait(Config.InjectionDelay) 
                                end
                            else
                                setStatus("FAILSAFE: Gagal pegang " .. obatToInject .. ". Server Lag.")
                            end
                        end
                    else
                        setStatus("Menunggu obat terisi / Memproses...")
                        task.wait(0.5)
                    end
                end
            else
                local acted = false
                local prompts = getPromptsNearBed(roomPath, bed)
                for _, desc in ipairs(prompts) do
                    local actText = string.lower(desc.ActionText or "")
                    local name = string.lower(desc.Name or "")
                    
                    if actText:match("inspect") then
                        -- LEWATI
                    elseif name == "firepp" or actText:match("burns") then
                        local hasOintment = LocalPlayer.Backpack:FindFirstChild("Ointment") or LocalPlayer.Character:FindFirstChild("Ointment")
                        if not hasOintment then fetchItem("Ointment", {"Ointment"}) end
                        
                        teleportToTarget(desc.Parent)
                        if turboSafeEquip("Ointment") then
                            local activeTool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
                            if activeTool and activeTool.Name == "Ointment" then
                                setStatus("Mengoleskan Ointment (Treat Burns)...")
                                simpleInteract(desc, 3, false)
                                acted = true; break
                            end
                        else
                            setStatus("Menunggu Ointment (Server Lag)...")
                        end
                        
                    elseif actText:match("dna") or name:match("dna") then
                        unequipAll() 
                        setStatus("Mengeklik: Take DNA Sample...")
                        simpleInteract(desc, 0.2, true)
                        justProcessedTick = tick()
                        acted = true; break
                        
                    elseif actText:match("analyze") or actText:match("process") then
                        unequipAll()
                        teleportToRoomCenter(roomNum, roomPath) 
                        
                        local oldReq = desc.RequiresLineOfSight
                        local oldDist = desc.MaxActivationDistance
                        desc.RequiresLineOfSight = false
                        desc.MaxActivationDistance = math.huge
                        
                        setStatus("Mengeklik: Mesin Lab/Process Results...")
                        if type(fireproximityprompt) == "function" then fireproximityprompt(desc, 1, true)
                        else desc:InputHoldBegan() task.wait(0.2) desc:InputHoldEnded() end
                        
                        desc.RequiresLineOfSight = oldReq
                        desc.MaxActivationDistance = oldDist
                        
                        justProcessedTick = tick()
                        acted = true; break
                    end
                end
                if acted then lastProgressTime = tick() task.wait(0.5) end
            end
        else
            task.wait(1)
        end
    end
end

-- ==========================================
-- SAFE MAIN EXECUTOR (WORKER THREAD)
-- ==========================================
local function botCycle()
    local activeShift = getShiftText()
    local fireNPC, firePP = getFireEmergency()
    if fireNPC then
        _G.AutoDoctor_IsIdle = false
        pcall(function() 
            unequipAll()
            local targetNode = fireNPC.PrimaryPart or fireNPC:FindFirstChildWhichIsA("BasePart")
            setStatus("! PRIORITAS 1: Memadamkan Pasien Terbakar !")
            simpleInteract(firePP, 3.2, targetNode)
            task.wait(1.5)
        end)
        return
    end

    local placePrompt, targetRoomName, _, _ = getPlacePatientPrompt()
    if placePrompt then
        _G.AutoDoctor_IsIdle = false
        pcall(function()
            unequipAll()
            setStatus("Membawa pasien pingsan ke " .. tostring(targetRoomName) .. "...")
            task.wait(0.2)
            setStatus("Meletakkan di kasur...")
            simpleInteract(placePrompt, 1, true)
            task.wait(1.5)
        end)
        return
    end

    local faintedPart, carryPP = getFaintedPatient()
    if faintedPart then
        _G.AutoDoctor_IsIdle = false
        pcall(function() processFaintedPatient(faintedPart, carryPP, activeShift) end)
        return
    end
    
    local room, roomNum = findActiveRoom()
    if room and roomNum then 
        _G.AutoDoctor_IsIdle = false
        pcall(function() executeTreatmentCore(room, roomNum, activeShift) end)
    else
        if not _G.AutoDoctor_IsIdle then
            unequipAll()
            teleportToIdle()
            _G.AutoDoctor_IsIdle = true
        end
        setStatus("Idle (Memantau )...")
        printRadarReport() 
        task.wait(Config.ScanDelay)
    end
end

local function startWorker()
    if _G.AutoDoctor_Worker then task.cancel(_G.AutoDoctor_Worker) end
    _G.AutoDoctor_Worker = task.spawn(function()
        while autoScanEnabled do
            if not isBusy then
                isBusy = true
                _G.AutoDoctor_LastActionTick = tick() 
                pcall(botCycle)
                isBusy = false
            end
            task.wait(0.1) 
        end
    end)
end

