local function getPendingMedicines(tvUI)
    local pending = {}
    if not tvUI then return pending end
    local invFolder = tvUI:FindFirstChild("inv", true)
    if not invFolder then return pending end
    
    for _, itemReq in ipairs(invFolder:GetChildren()) do
        if table.find(ItemList, itemReq.Name) then 
            local checkMark = itemReq:FindFirstChild("check")
            if not checkMark or (checkMark and checkMark.Visible == false) then 
                table.insert(pending, itemReq.Name) 
            end
        end
    end
    return pending
end

local function getPromptsNearBed(roomPath, bedPart)
    local prompts = {}
    if not roomPath or not bedPart then return prompts end
    
    local minigame = roomPath:FindFirstChild("Minigame")
    if minigame then
        for _, desc in ipairs(minigame:GetDescendants()) do
            if desc:IsA("ProximityPrompt") and desc.Enabled then
                table.insert(prompts, desc)
            end
        end
    end
    
    if workspace:FindFirstChild("NPCs") then
        for _, npc in ipairs(workspace.NPCs:GetChildren()) do
            local p = npc.PrimaryPart or npc:FindFirstChildWhichIsA("BasePart")
            if p and (p.Position - bedPart.Position).Magnitude <= Config.PatientBedRadius then
                for _, desc in ipairs(npc:GetDescendants()) do
                    if desc:IsA("ProximityPrompt") and desc.Enabled then
                        table.insert(prompts, desc)
                    end
                end
            end
        end
    end
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local p = player.Character.PrimaryPart or player.Character:FindFirstChildWhichIsA("BasePart")
            if p and (p.Position - bedPart.Position).Magnitude <= Config.PatientBedRadius then
                for _, desc in ipairs(player.Character:GetDescendants()) do
                    if desc:IsA("ProximityPrompt") and desc.Enabled then
                        table.insert(prompts, desc)
                    end
                end
            end
        end
    end
    
    return prompts
end

local function isPatientReady(roomPath, bedPart)
    local minigame = roomPath:FindFirstChild("Minigame")
    local tvUI = minigame and minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen", true)
    
    local pending = getPendingMedicines(tvUI)
    if #pending > 0 then return true, "TV Aktif (Butuh Obat)" end
    
    local prompts = getPromptsNearBed(roomPath, bedPart)
    for _, desc in ipairs(prompts) do
        local actText = string.lower(desc.ActionText or "")
        local name = string.lower(desc.Name or "")
        
        if actText:match("inspect") then
            -- Skip inspect
        elseif actText:match("dna") or name:match("dna") then 
            return true, "Tombol DNA" 
        elseif actText:match("burns") or name == "firepp" then 
            return true, "Tombol Luka Bakar" 
        elseif actText:match("analyze") or actText:match("process") or name:match("analyze") then 
            return true, "Mesin Lab" 
        end
    end
    
    return false, "Kosong/Healing"
end

local function isHealingDone(minigame, roomPath, bedPart)
    if not minigame then return false end
    
    local tv = minigame:FindFirstChild("TV")
    local screen = tv and tv:FindFirstChild("Screen")
    local ui = screen and screen:FindFirstChild("UI")
    local healing = ui and ui:FindFirstChild("Healing")
    
    if healing and healing:IsA("GuiObject") and healing.Visible == true then
        if roomPath and bedPart then
            local ready, reason = isPatientReady(roomPath, bedPart)
            -- FAKTA FISIK MURNI: Jika siap, Healing ini dianggap BUG (kecuali TV minta obat, itu transisi)
            if ready and reason ~= "TV Aktif (Butuh Obat)" then 
                return false 
            end
        end
        return true 
    end
    return false
end

local function checkAnomalyStatus(bedPart)
    if not bedPart then return false end
    if workspace:FindFirstChild("NPCs") then
        for _, npc in ipairs(workspace.NPCs:GetChildren()) do
            local p = npc.PrimaryPart or npc:FindFirstChildWhichIsA("BasePart")
            if p and (p.Position - bedPart.Position).Magnitude <= Config.PatientBedRadius then
                local attr = npc:GetAttributes()
                if attr.Skinwalker or attr.SkinwalkerEasy or attr.PenaltyWhenLettingIn or attr.PhotoEffect == "CursedPhoto" or attr.PhotoEffect2 == "CursedPhoto" then 
                    return true 
                end
            end
        end
    end
    return false
end

local function printRadarReport()
    if not Config.ShowConsoleLogs then return end
    local report = "[RADAR] Live Scan: "
    local roomsFolder = workspace:FindFirstChild("Rooms")
    local medicalFolder = roomsFolder and roomsFolder:FindFirstChild("Medical")
    if not medicalFolder then return end

    for i = 1, Config.MaxRooms do
        local room = medicalFolder:FindFirstChild("Room" .. i)
        local status = "[-]"
        if room then
            local minigame = room:FindFirstChild("Minigame")
            local bed = minigame and minigame:FindFirstChild("Bed") and minigame.Bed:FindFirstChild("InBed")
            
            local isBlacklisted = BuggedRoomBlacklist[i] and (tick() - BuggedRoomBlacklist[i] < Config.BlacklistDuration)
            local isHealing = isHealingDone(minigame, room, bed)
            local ready, reason = isPatientReady(room, bed)
            
            if ready and not isHealing then
                _G.AutoDoctor_RoomMemory[i] = nil 
                status = "[" .. reason .. "]"
            elseif isBlacklisted then
                status = "[BLACKLIST]"
            elseif _G.AutoDoctor_RoomMemory[i] == "PatientLeaving" then
                status = "[MEMORI: Pasien Lama Keluar]"
            elseif isHealing then
                status = "[HEALING]"
            else
                local signLight = room:FindFirstChild("MainSign") and room.MainSign:FindFirstChild("Light")
                local isLightRed = signLight and (signLight.BrickColor.Name == "Crimson" or signLight.Color == Color3.fromRGB(165, 0, 0))
                if isLightRed then
                    status = "[Lampu Merah: Pasien Baru Menuju]"
                else
                    status = "[Kosong]"
                end
            end
        end
        report = report .. "R" .. i .. ":" .. status .. " "
    end
    
    if _G.LastRadarReport ~= report then
        _G.LastRadarReport = report
        local timeStamp = os.date("%H:%M:%S")
        print("[" .. timeStamp .. "] [Auto-Doctor] " .. report)
    end
end

