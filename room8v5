        local lastShift = getShiftText()
        startWorkerRoom8()
        
        if _G.Room8Auto_Watchdog then task.cancel(_G.Room8Auto_Watchdog) end
        _G.Room8Auto_Watchdog = task.spawn(function()
            while autoScanEnabled do
                task.wait(1)
                
                local currentShift = getShiftText()
                local isShiftChanged = (currentShift ~= lastShift and currentShift ~= nil and lastShift ~= nil)
                local isStuck = isBusy and (tick() - _G.Room8Auto_LastActionTick > Config.GlobalStuckTimeout)

                if isShiftChanged or isStuck then
                    if isShiftChanged then
                        setStatus("Shift Berganti! HARD-RESET...")
                    else
                        setStatus("SYSTEM STUCK! AUTO HARD-RESET...")
                    end
                    
                    if _G.Room8Auto_Worker then task.cancel(_G.Room8Auto_Worker) end
                    
                    isBusy = false
                    isBotIdle = false
                    lastShift = currentShift
                    teleportToTarget(Config.IdleCFrame)
                    task.wait(2)
                    
                    if autoScanEnabled then
                        _G.Room8Auto_LastActionTick = tick()
                        startWorkerRoom8()
                    end
                end
                
                if currentShift then lastShift = currentShift end
            end
        end)
    else
        ToggleAutoBtn.Text = "Auto Room 8: OFF"
        ToggleAutoBtn.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
        if _G.Room8Auto_Watchdog then task.cancel(_G.Room8Auto_Watchdog) end
        if _G.Room8Auto_Worker then task.cancel(_G.Room8Auto_Worker) end
        isBusy = false 
        isBotIdle = false
        setStatus("Dimatikan.")
    end
end)
