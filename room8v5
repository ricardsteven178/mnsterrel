local function isRoom8Active()
    local room = workspace:FindFirstChild("Rooms") and workspace.Rooms:FindFirstChild("Emergency") and workspace.Rooms.Emergency:FindFirstChild("Room8")
    if room then
        local signLight = room:FindFirstChild("MainSign") and room.MainSign:FindFirstChild("Light")
        if signLight and signLight:IsA("BasePart") and (signLight.BrickColor.Name == "Crimson" or signLight.Color == Color3.fromRGB(165, 0, 0)) then
            if not isRoom8HealingDone(room) then return room end
        end
    end
    return nil
end

local function executeRoom8Treatment(room8, activeShift)
    local minigame = room8:FindFirstChild("Minigame")
    if not minigame or getShiftText() ~= activeShift then return end

    setStatus("--- TURBO SURGERY DIMULAI ---")
    local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if root then
        root.CFrame = Config.Room8BedCFrame
        root.AssemblyLinearVelocity = Vector3.zero
    end

    local ui = minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen") and minigame.TV.Screen:FindFirstChild("UI")
    local reportFolder = ui and ui:FindFirstChild("Report")
    local treatmentText = reportFolder and reportFolder:FindFirstChild("treatment")
    local bed = minigame:FindFirstChild("Bed") and minigame.Bed:FindFirstChild("InBed")

    setStatus("1/3 Menunggu fisik pasien di kasur...")
    local targetNPC = nil
    local waitNPC = 0
    while not targetNPC and waitNPC < 20 do
        ensureInRoom8() 
        if getShiftText() ~= activeShift then return end
        
        if workspace:FindFirstChild("NPCs") then
            for _, npc in ipairs(workspace.NPCs:GetChildren()) do
                local part = npc.PrimaryPart or npc:FindFirstChildWhichIsA("BasePart")
                if part and (part.Position - Config.Room8BedCFrame.Position).Magnitude < Config.PatientBedRadius then
                    targetNPC = npc
                    break
                end
            end
        end
        if not targetNPC then
            task.wait(0.5)
            waitNPC = waitNPC + 1
        end
    end

    if not targetNPC then
        setStatus("BATAL: Pasien gagal sampai ke kasur.")
        return
    end

    setStatus("2/3 Menidurkan pasien...")
    local waitLimit = 0
    while treatmentText and treatmentText.Text ~= "BEGIN SURGERY:" and waitLimit < 40 do
        ensureInRoom8() 
        _G.Room8Auto_LastActionTick = tick() 
        
        if isRoom8HealingDone(room8) or getShiftText() ~= activeShift then return end
        
        local sleepPP = bed and bed:FindFirstChild("PP2")
        if sleepPP and sleepPP.Enabled then
            simpleInteract(sleepPP, 0.1, false)
        end
        
        task.wait(0.2) 
        waitLimit = waitLimit + 1
    end

    setStatus("3/3 Mulai Apply Treatment...")
    local lastProgressTime = tick()

    while true do
        task.wait(0.05) 
        _G.Room8Auto_LastActionTick = tick() 
        ensureInRoom8()

        if getShiftText() ~= activeShift then setStatus("Shift berganti. Stop.") break end
        if isRoom8HealingDone(room8) then setStatus("Surgery Selesai! Layar Hijau.") break end

        local signLight = room8:FindFirstChild("MainSign") and room8.MainSign:FindFirstChild("Light")
        if not signLight or (signLight.BrickColor.Name ~= "Crimson" and signLight.Color ~= Color3.fromRGB(165, 0, 0)) then break end

        if tick() - lastProgressTime >= Config.StuckTimeout then 
            setStatus("Local Loop Timeout. Skip.")
            break 
        end

        local patientIsAnomaly = checkAnomalyStatus()
        local currentPending = getPendingMedicinesRoom8(reportFolder)
        
        -- =====================================
        -- [ ANOMALY KILLER LOGIC ]
        -- =====================================
        if patientIsAnomaly and #currentPending > 0 then
            local wrongMedicine = "Medicine"
            for _, item in ipairs(ItemList) do
                if not table.find(currentPending, item) then wrongMedicine = item break end
            end
            
            local hasIt = LocalPlayer.Backpack:FindFirstChild(wrongMedicine) or LocalPlayer.Character:FindFirstChild(wrongMedicine)
            if not hasIt then 
                setStatus("Telekinesis Racun: " .. wrongMedicine)
                smartFetch(wrongMedicine, {wrongMedicine}) 
            end
            
            local hasItNow = LocalPlayer.Backpack:FindFirstChild(wrongMedicine) or LocalPlayer.Character:FindFirstChild(wrongMedicine)
            if hasItNow then
                if bed and bed:FindFirstChild("PP") then
                    ensureInRoom8()
                    if safeEquip(wrongMedicine) then
                        setStatus("MENYUNTIKKAN RACUN: " .. wrongMedicine)
                        simpleInteract(bed.PP, 0.1, true)
                        lastProgressTime = tick() 
                        task.wait(1.5) 
                        setStatus("--- ANOMALI HANGUS! ---")
                        break 
                    else
                        setStatus("FAILSAFE: Gagal pegang racun. Server Lag.")
                        task.wait(0.5)
                    end
                end
            else
                setStatus("Gagal mengambil racun: " .. wrongMedicine)
                task.wait(0.5)
            end
            
        -- =====================================
        -- [ NORMAL TREATMENT LOGIC (FIX V16) ]
        -- =====================================
        else
            if #currentPending == 0 then continue end

            -- [ FIX: SMART MATH BATCH FETCHING ] Menghitung kebutuhan spesifik setiap obat!
            local reqCounts = {}
            for _, obat in ipairs(currentPending) do reqCounts[obat] = (reqCounts[obat] or 0) + 1 end
            
            local _, currentItems = checkTotalInventory()
            local haveCounts = {}
            for _, item in ipairs(currentItems) do haveCounts[item.Name] = (haveCounts[item.Name] or 0) + 1 end

            local isMissingItems = false
            for obat, needed in pairs(reqCounts) do
                local have = haveCounts[obat] or 0
                if have < needed then
                    for i = 1, (needed - have) do
                        setStatus("Telekinesis: " .. obat .. " ("..have+i.."/"..needed..")")
                        smartFetch(obat, currentPending)
                        isMissingItems = true
                    end
                end
            end
            if isMissingItems then task.wait(0.1) end 

            -- Evaluasi antrian lagi, baru disuntik!
            local obatToInject = currentPending[1]
            local hasItNow = LocalPlayer.Backpack:FindFirstChild(obatToInject) or LocalPlayer.Character:FindFirstChild(obatToInject)
            
            if hasItNow then
                local applyPP = bed and bed:FindFirstChild("PP")
                if applyPP then
                    ensureInRoom8()
                    if safeEquip(obatToInject) then
                        task.wait(0.2) -- Jeda aman server membaca equip
                        local previousPendingCount = #currentPending
                        
                        setStatus("Menerapkan: " .. obatToInject)
                        simpleInteract(applyPP, 0.1, true)
                        lastProgressTime = tick()
                        
                        -- [ FIX: COUNT SYNC ] Nunggu berdasarkan sisa obat di TV!
                        setStatus("Menunggu obat terproses di TV...")
                        local waitCheckLimit = 0
                        while waitCheckLimit < 30 do 
                            local newPending = getPendingMedicinesRoom8(reportFolder)
                            if #newPending < previousPendingCount then 
                                break -- BERHASIL: Total item di TV berkurang!
                            end
                            
                            if isRoom8HealingDone(room8) or getShiftText() ~= activeShift then break end
                            task.wait(0.05) 
                            waitCheckLimit = waitCheckLimit + 1
                            _G.Room8Auto_LastActionTick = tick()
                        end
                    else
                        setStatus("FAILSAFE: Gagal pegang obat " .. obatToInject .. ", Server lag...")
                        task.wait(0.5)
                    end
                end
            else
                setStatus("Gagal Telekinesis " .. obatToInject .. ", mengulang...")
                task.wait(0.5)
            end
        end
    end
end

-- ==========================================
-- SAFE MAIN EXECUTOR (WORKER THREAD)
-- ==========================================
local function botCycleRoom8()
    local activeShift = getShiftText()
    
    if activeShift == "" or not activeShift or activeShift:match("Istirahat") then
        if not isBotIdle then 
            teleportToTarget(Config.IdleCFrame)
            isBotIdle = true
        end
        setStatus("Istirahat/Luar Shift...")
        task.wait(2)
        return
    end

    local room8 = workspace:FindFirstChild("Rooms") and workspace.Rooms:FindFirstChild("Emergency") and workspace.Rooms.Emergency:FindFirstChild("Room8")
    local roomActive = nil
    if room8 then
        local signLight = room8:FindFirstChild("MainSign") and room8.MainSign:FindFirstChild("Light")
        if signLight and signLight:IsA("BasePart") and (signLight.BrickColor.Name == "Crimson" or signLight.Color == Color3.fromRGB(165, 0, 0)) then
            if not isRoom8HealingDone(room8) then roomActive = room8 end
        end
    end

    if roomActive then
        isBotIdle = false 
        pcall(function() executeRoom8Treatment(roomActive, activeShift) end)
    else
        if not isBotIdle then 
            teleportToTarget(Config.IdleCFrame)
            isBotIdle = true
        end
        setStatus("Menunggu Kasus Room 8 (" .. activeShift .. ")...")
        task.wait(Config.ScanDelay)
    end
end

local function startWorkerRoom8()
    if _G.Room8Auto_Worker then task.cancel(_G.Room8Auto_Worker) end
    _G.Room8Auto_Worker = task.spawn(function()
        while autoScanEnabled do
            if not isBusy then
                isBusy = true
                _G.Room8Auto_LastActionTick = tick() 
                local success, err = pcall(botCycleRoom8)
                if not success then
                    setStatus("SYSTEM ERROR: " .. tostring(err))
                    task.wait(2)
                end
                isBusy = false
            end
            task.wait(0.2)
        end
    end)
end

