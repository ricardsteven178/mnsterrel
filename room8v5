local function setStatus(text)
    StatusLabel.Text = "Status: " .. text
    if Config.ShowConsoleLogs and text ~= lastLoggedText then 
        print("[Room8-V16] " .. text) 
        lastLoggedText = text
    end
end

local function teleportToTarget(target)
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root or not target then return end
    
    local posToTP = nil
    if typeof(target) == "CFrame" then posToTP = target.Position
    elseif typeof(target) == "Vector3" then posToTP = target
    elseif target:IsA("BasePart") then posToTP = target.Position
    end
    
    if posToTP then
        root.CFrame = CFrame.new(posToTP + Vector3.new(0, 3, 0))
        root.AssemblyLinearVelocity = Vector3.zero
        task.wait(0.1) 
    end
end

local function ensureInRoom8()
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if root then
        local distance = (root.Position - Config.Room8BedCFrame.Position).Magnitude
        if distance > 20 then
            setStatus("Anchor: Mengembalikan ke kasur Room 8...")
            root.CFrame = Config.Room8BedCFrame
            root.AssemblyLinearVelocity = Vector3.zero
            task.wait(0.2)
        end
    end
end

