local function getSlots()
    local slots = {}
    for _, pp in ipairs(CollectionService:GetTagged("ShopItemPP")) do
        pcall(function()
            if not pp.Enabled then return end
            local model = pp.Parent
            if not model or model:FindFirstChild("SoldOut") then return end
            local entry = { pp=pp, name="?", type="?", cost=0 }
            for _, label in ipairs(model:GetDescendants()) do
                if label:IsA("TextLabel") and label.Text and #label.Text > 0 then
                    local n = label.Name:lower()
                    if n == "description" then entry.name = label.Text
                    elseif n == "type" then
                        entry.type = label.Text:gsub("[%[%]]",""):match("^%s*(.-)%s*$")
                    elseif n == "cost" then
                        entry.cost = tonumber(label.Text:gsub("[%$,]",""):match("^%s*(.-)%s*$")) or 0
                    end
                end
            end
            if entry.name ~= "?" then table.insert(slots, entry) end
        end)
    end
    return slots
end

local function getPriority(name)
    local list = config.mode == "TOOL" and ShopDatabase.TOOL
        or config.mode == "UPGRADE" and ShopDatabase.UPGRADE
        or (function()
            local merged = {}
            for _, v in ipairs(ShopDatabase.TOOL) do table.insert(merged, v) end
            for _, v in ipairs(ShopDatabase.UPGRADE) do table.insert(merged, v) end
            return merged
        end)()
    for i, item in ipairs(list) do
        if item.name:lower() == name:lower() then return i end
    end
    return 999
end

local logCallback = nil -- diisi GUI nanti

local function addLog(msg, success)
    table.insert(buyLog, 1, { text=msg, success=success })
    if #buyLog > 15 then table.remove(buyLog) end
    if logCallback then logCallback() end
end

function tryBuy()
    if not _G.AxiomAutoBuyActive == myToken then return end
    if not config.enabled or isBuying then return end
    if config.mode == "NONE" then return end
    isBuying = true

    readCash()
    local slots = getSlots()
    local candidates = {}

    for _, slot in ipairs(slots) do
        if boughtThisShop[slot.name] then continue end
        local typeMatch = config.mode == "ALL"
            or (config.mode == slot.type)
        local budgetOk = config.budget == 0 or slot.cost <= config.budget
        local cashOk = slot.cost <= localCash
        if typeMatch and budgetOk and cashOk then
            slot.priority = getPriority(slot.name)
            table.insert(candidates, slot)
        end
    end

    table.sort(candidates, function(a,b) return a.priority < b.priority end)

    if #candidates == 0 then
        isBuying = false
        return
    end

    local target = candidates[1]
    local char = lp.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then isBuying = false return end

    -- Teleport ke slot
    local slotName = target.pp.Parent.Name
    local targetPos = SlotPositions[slotName]
    if targetPos then
        hrp.CFrame = CFrame.new(targetPos + Vector3.new(4, 0, 0))
            * CFrame.Angles(0, -math.pi/2, 0)
    end

    task.wait(CONFIG.teleportWait)

    -- Snapshot cash sebelum beli
    readCash()
    local cashBefore = localCash

    fireproximityprompt(target.pp)

    -- Konfirmasi via cash berkurang
    local confirmed = false
    local elapsed = 0
    while elapsed < CONFIG.confirmTimeout do
        task.wait(0.2)
        elapsed = elapsed + 0.2
        readCash()
        if localCash <= cashBefore - target.cost then
            confirmed = true
            break
        end
    end

    if confirmed then
        boughtThisShop[target.name] = true
        addLog(string.format("✅ %s ($%d)", target.name, target.cost), true)
        isBuying = false
        task.wait(CONFIG.buyDelay)
        tryBuy()
    else
        addLog(string.format("❌ %s — retry", target.name), false)
        isBuying = false
        task.wait(0.5)
        tryBuy()
    end
end

