local function readCash()
    local ok, val = pcall(function()
        return lp.PlayerGui.Sanity.Frame.cash.Text
    end)
    if ok and val then
        local num = val:gsub("%$",""):gsub(",",""):match("^%s*(.-)%s*$")
        localCash = tonumber(num) or 0
    end
end

