-- HELPER: DEBUG LOGS & PATHFINDER
-- ==========================================
local function debugLog(message, isWarning)
    if Config.ShowConsoleLogs then
        if isWarning then
            warn(message)
        else
            print(message)
        end
    end
end

local function getRoomFromPath(pathTable)
    local current = workspace
    for _, name in ipairs(pathTable) do
        if current then
            current = current:FindFirstChild(name)
        end
    end
    return current
end

