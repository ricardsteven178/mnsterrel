-- ==========================================
-- MOUSE UNLOCK LOGIC
-- ==========================================
local function applyMouseUnlock(state)
    mouseUnlockEnabled = state
    if state then
        pcall(function() LocalPlayer.DevEnableMouseLock = false end)
        if mouseUnlockConn then mouseUnlockConn:Disconnect() end
        mouseUnlockConn = RunService.RenderStepped:Connect(function()
            if not mouseUnlockEnabled then return end
            pcall(function()
                if LocalPlayer.CameraMode == Enum.CameraMode.LockFirstPerson then
                    LocalPlayer.CameraMode = Enum.CameraMode.Classic
                end
                LocalPlayer.CameraMaxZoomDistance = 400
                if LocalPlayer.CameraMinZoomDistance > 0.5 then
                    LocalPlayer.CameraMinZoomDistance = 0.5
                end
            end)
            if UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
                if UserInputService.MouseBehavior ~= Enum.MouseBehavior.LockCurrentPosition then
                    UserInputService.MouseBehavior = Enum.MouseBehavior.LockCurrentPosition
                end
            else
                if UserInputService.MouseBehavior ~= Enum.MouseBehavior.Default then
                    UserInputService.MouseBehavior = Enum.MouseBehavior.Default
                end
            end
            if not UserInputService.MouseIconEnabled then
                UserInputService.MouseIconEnabled = true
            end
            pcall(function()
                local mouse = LocalPlayer:GetMouse()
                if mouse and mouse.Icon ~= "" then mouse.Icon = "" end
            end)
            pcall(function()
                if LocalPlayer.DevEnableMouseLock then
                    LocalPlayer.DevEnableMouseLock = false
                end
            end)
        end)
    else
        if mouseUnlockConn then mouseUnlockConn:Disconnect(); mouseUnlockConn = nil end
    end
end

-- Keybind global Y
UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    if input.KeyCode == currentMouseKeybindCode then
        mouseUnlockEnabled = not mouseUnlockEnabled
        applyMouseUnlock(mouseUnlockEnabled)
        if updateMouseUnlockUI then updateMouseUnlockUI(mouseUnlockEnabled) end
    end
end)

