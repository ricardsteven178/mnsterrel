local function godifySanity()
    pcall(function()
        SanityEvent:FireServer(NaN, "Heal your Sanity")
        LocalPlayer:SetAttribute("Sanity", NaN)
    end)
end

local function toggleSanityState()
    if getgenv().AutoSanityIsRunning then
        SanityStatusLabel.Text = "Sanity: Max (God Mode)"
        SanityStatusLabel.TextColor3 = Color3.fromRGB(85, 255, 255)

        godifySanity()

        if getgenv().AutoSanityLoop then task.cancel(getgenv().AutoSanityLoop) end
        getgenv().AutoSanityLoop = task.spawn(function()
            while getgenv().AutoSanityIsRunning do
                task.wait(30)
                if getgenv().AutoSanityIsRunning then godifySanity() end
            end
        end)
    else
        SanityStatusLabel.Text = "Sanity: Normal"
        SanityStatusLabel.TextColor3 = Color3.fromRGB(200, 200, 80)

        if getgenv().AutoSanityLoop then
            task.cancel(getgenv().AutoSanityLoop)
            getgenv().AutoSanityLoop = nil
        end
        pcall(function() LocalPlayer:SetAttribute("Sanity", 100) end)
        debugLog("God OFF. Server NaN persists until next shift/respawn.", false)
    end
end

