local function isMachineReady(machine)
	local statusUI = machine:FindFirstChild("Attachment") and machine.Attachment:FindFirstChild("UI") and machine.Attachment.UI:FindFirstChild("status")
	if statusUI then
		local cleanText = string.lower(string.gsub(statusUI.Text, "<[^>]+>", ""))
		if string.find(cleanText, "brewing") or string.match(cleanText, "%d+") then return false end
		if string.find(cleanText, "ready") then return true end
	end
	return false
end

local function getMachineInfo(machineName)
	local machine = workspace.Misc:FindFirstChild(machineName)
	if not machine then return "-" end
	if isMachineReady(machine) then return '<font color="rgb(50, 255, 50)">Ready</font>' end
	local statusUI = machine:FindFirstChild("Attachment") and machine.Attachment:FindFirstChild("UI") and machine.Attachment.UI:FindFirstChild("status")
	if statusUI then
		local cleanText = string.gsub(statusUI.Text, "<[^>]+>", "") 
		local timeMatch = string.match(cleanText, "%d+s") 
		if timeMatch then return timeMatch end
	end
	return "Wait"
end

local function updateMachineStatusUI()
	MachineStatus.Text = "K1: " .. getMachineInfo("CoffeeMachine") .. " | K2: " .. getMachineInfo("CoffeeMachine2")
end

-- ==========================================
-- 📊 FUNGSI SELEKSI & AUTO-SORT KOPI
-- ==========================================
local function getCoffeeDebugData()
	local totalUtama = 0
	local totalBekas = 0
	local sipsArray = {}
	local savedBekasInstances = {} 
	local currentTools = {}
	
	local character = LocalPlayer.Character
	local backpack = LocalPlayer:FindFirstChild("Backpack")
	
	local function scanFolder(folder)
		if not folder then return end
		for _, item in pairs(folder:GetChildren()) do
			if item:IsA("Tool") and string.find(string.lower(item.Name), "coffee") then
				table.insert(currentTools, item)
			end
		end
	end
	scanFolder(backpack)
	scanFolder(character)
	
	for toolInst, _ in pairs(CoffeeTracker) do
		if not toolInst.Parent or (toolInst.Parent ~= backpack and toolInst.Parent ~= character) then
			CoffeeTracker[toolInst] = nil
			lastSipTime[toolInst] = nil
			if toolConnections[toolInst] then
				toolConnections[toolInst]:Disconnect()
				toolConnections[toolInst] = nil
			end
		end
	end
	
	for _, toolInst in ipairs(currentTools) do
		if not CoffeeTracker[toolInst] then
			globalCoffeeCounter = globalCoffeeCounter + 1
			CoffeeTracker[toolInst] = {
				sips = Config.MaxTegukPerKopi,
				bornId = globalCoffeeCounter 
			}
		end
		
		if not toolConnections[toolInst] then
			toolConnections[toolInst] = toolInst.Activated:Connect(function()
				if not lastSipTime[toolInst] or (tick() - lastSipTime[toolInst]) >= Config.JedaMinum then
					lastSipTime[toolInst] = tick()
					if CoffeeTracker[toolInst] then
						CoffeeTracker[toolInst].sips = CoffeeTracker[toolInst].sips - 1
					end
				end
			end)
		end
	end
	
	local sortedTools = {}
	for _, t in ipairs(currentTools) do table.insert(sortedTools, t) end
	table.sort(sortedTools, function(a, b) 
		return CoffeeTracker[a].bornId < CoffeeTracker[b].bornId 
	end)
	
	for _, toolInst in ipairs(sortedTools) do
		local sips = CoffeeTracker[toolInst].sips
		
		if sips == 1 and totalBekas < Config.SimpanKopiBekas then
			totalBekas += 1
			savedBekasInstances[toolInst] = true
			table.insert(sipsArray, "B" .. totalBekas .. ":" .. sips .. "x")
		else
			totalUtama += 1
			table.insert(sipsArray, "K" .. totalUtama .. ":" .. sips .. "x")
		end
	end
	
	local debugString = table.concat(sipsArray, " | ")
	if debugString == "" then debugString = "Tas Kosong, Butuh Kopi" end
	
	return totalUtama, totalBekas, savedBekasInstances, debugString
end

local function getCurrentSanity()
	local PlayerGui = LocalPlayer:FindFirstChild("PlayerGui")
	if not PlayerGui then return 100 end
	
	local amountUI = PlayerGui:FindFirstChild("Sanity") and PlayerGui.Sanity:FindFirstChild("Frame") and PlayerGui.Sanity.Frame:FindFirstChild("Frame") and PlayerGui.Sanity.Frame.Frame:FindFirstChild("textbox") and PlayerGui.Sanity.Frame.Frame.textbox:FindFirstChild(Config.TargetSanityUI)
	if amountUI then return tonumber(string.match(amountUI.Text, "%d+")) or 100 end
	return 100 
end

local function handleCoffeeDrinking()
	if not isSystemActive then return end 
	
	local currentSanity = getCurrentSanity()
	local totalUtama, totalBekas, savedBekasInstances, debugString = getCoffeeDebugData()
	
	SanityStatus.Text = "🧠 Sanity: " .. currentSanity .. "%"
	FarmStatus.Text = "🎒 Utama: " .. totalUtama .. "/" .. Config.MaxKopiDiTas .. " | Bekas: " .. totalBekas .. "/" .. Config.SimpanKopiBekas
	SipsDebugLog.Text = "📊 " .. debugString
	
	local character = LocalPlayer.Character
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	local backpack = LocalPlayer:FindFirstChild("Backpack")
	if not character or not humanoid or not backpack then return end

	if currentSanity <= Config.BatasMinum then
		local validCoffeeToDrink = nil
		
		local heldItem = character:FindFirstChildOfClass("Tool")
		if heldItem and string.find(string.lower(heldItem.Name), "coffee") then
			if savedBekasInstances[heldItem] then
				humanoid:UnequipTools()
			else
				validCoffeeToDrink = heldItem
			end
		end
		
		if not validCoffeeToDrink then
			for _, item in pairs(backpack:GetChildren()) do
				if item:IsA("Tool") and string.find(string.lower(item.Name), "coffee") then
					if not savedBekasInstances[item] then
						humanoid:EquipTool(item)
						validCoffeeToDrink = item
						task.wait(0.2) 
						break
					end
				end
			end
		end
		
		if validCoffeeToDrink then
			validCoffeeToDrink:Activate() 
			UpdateActionLog("☕ Teguk Kopi! Sanity: " .. currentSanity .. "%")
			task.wait(Config.JedaMinum) 
		else
			if totalUtama == 0 and totalBekas > 0 then
				UpdateActionLog("⚠️ Butuh Kopi Utama! (Bekas Diamankan)")
			end
		end
	else
		local heldItem = character:FindFirstChildOfClass("Tool")
		if heldItem and string.find(string.lower(heldItem.Name), "coffee") then
			humanoid:UnequipTools()
		end
	end
end

-- ==========================================
-- LOGIKA TELEPORT & AMBIL KOPI 
-- ==========================================
local function takeCoffee(machine)
	if not isAutoRunning or not isSystemActive then return end
	
	local totalUtama, _, _, _ = getCoffeeDebugData()
	if totalUtama >= Config.MaxKopiDiTas then return end
	if not isMachineReady(machine) then return end

	local prompt = nil
	for _, obj in pairs(machine:GetDescendants()) do
		if obj:IsA("ProximityPrompt") and obj.Enabled then
			local actText = string.lower(obj.ActionText)
			local objText = string.lower(obj.ObjectText)
			if not string.find(actText, "buy") and not string.find(objText, "instant") then
				prompt = obj
				break
			end
		end
	end

	if not prompt then return end

	local character = LocalPlayer.Character
	local rootPart = character and character:FindFirstChild("HumanoidRootPart")
	
	if rootPart then
		local originalPos = rootPart.CFrame
		rootPart.CFrame = coffeeStandCFrame
		
		task.wait(Config.DelayTeleport) 
		
		if isMachineReady(machine) and prompt.Enabled then
			fireproximityprompt(prompt)
			UpdateActionLog("⚡ Mengambil Kopi Utama dari " .. machine.Name)
		else
			UpdateActionLog("🛑 Batal! Mesin nge-glitch (Desync).")
		end
		
		task.wait(Config.DelayKembali)
		rootPart.CFrame = originalPos
	end
end

