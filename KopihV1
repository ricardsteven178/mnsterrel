-- ==========================================
-- 🪄 FUNGSI SUMMON MESIN 2 (DIPISAH AGAR BISA AUTO)
-- ==========================================
local function DoSummonMachine2()
	local machine2 = workspace:FindFirstChild("CoffeeMachine2", true) or ReplicatedStorage:FindFirstChild("CoffeeMachine2", true)
	local machine1 = workspace:FindFirstChild("Misc") and workspace.Misc:FindFirstChild("CoffeeMachine")
	
	if machine2 then
		if machine2.Parent ~= workspace:FindFirstChild("Misc") then
			machine2.Parent = workspace:FindFirstChild("Misc")
		end
		
		if machine1 then
			local baseCFrame = machine1:IsA("Model") and machine1:GetPivot() or machine1.CFrame
			local offsetCFrame = baseCFrame * CFrame.new(-2.5, -0.5, -0.8)
			local finalCFrame = offsetCFrame * CFrame.Angles(0, 0, math.rad(90))
			
			if machine2:IsA("Model") then
				machine2:PivotTo(finalCFrame)
			elseif machine2:IsA("BasePart") then
				machine2.CFrame = finalCFrame
			end
		else
			local pos = coffeeStandCFrame.Position + Vector3.new(0, 3, 0)
			local fallbackCFrame = CFrame.new(pos) * CFrame.Angles(0, 0, math.rad(90))
			if machine2:IsA("Model") then
				machine2:PivotTo(fallbackCFrame)
			elseif machine2:IsA("BasePart") then
				machine2.CFrame = fallbackCFrame
			end
		end
		
		for _, part in pairs(machine2:GetDescendants()) do
			if part:IsA("BasePart") then
				part.Anchored = true
			end
		end
		
		setupMachine(machine2)
		UpdateActionLog("🪄 Mesin Kopi 2 Pas di Meja & Maju!")
	else
		UpdateActionLog("❌ Gagal: CoffeeMachine2 tidak ada di map!")
	end
end

